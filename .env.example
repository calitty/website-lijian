# Copy to .env for local dev, and set the same keys as Cloudflare Pages variables.
# PUBLIC_* are build-time variables (must be set as Build variables, then redeploy).
# Non-PUBLIC keys (RESEND_API_KEY) are runtime secrets.

# --- Site ---
PUBLIC_SITE_URL=https://lijianblades.com

# --- Analytics (scripts only load when the matching id is set) ---
PUBLIC_GA_MEASUREMENT_ID=
PUBLIC_YANDEX_METRICA_ID=
PUBLIC_CLARITY_PROJECT_ID=

# --- Search engine site verification (needed before submitting sitemaps) ---
# Get each value from the verification step in:
#   Google Search Console / Bing Webmaster Tools / Yandex Webmaster
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=
PUBLIC_YANDEX_SITE_VERIFICATION=
# China search engines — verify + submit sitemap in each platform:
#   Baidu 百度搜索资源平台 (ziyuan.baidu.com) / Sogou 搜狗站长 / 360 站长
PUBLIC_BAIDU_SITE_VERIFICATION=
PUBLIC_SOGOU_SITE_VERIFICATION=
PUBLIC_360_SITE_VERIFICATION=

# --- Inquiry email (Cloudflare Pages Function /api/inquiry, via Resend) ---
RESEND_API_KEY=
INQUIRY_FROM_EMAIL=Website Inquiry <inquiry@send.lijianblades.com>
INQUIRY_TO_EMAIL=yijiangyaoqu@gmail.com
