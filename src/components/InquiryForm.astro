const isDark = tone === "dark";
const panelClass = isDark
  ? "rounded-[6px] border border-white/10 bg-[#0b1520] p-4"
  : "rounded-[6px] border border-slate-200 bg-white p-5 shadow-sm";
const labelClass = isDark ? "text-slate-300" : "text-slate-700";
const inputClass = isDark
  ? "mt-1 w-full rounded-[4px] border border-white/10 bg-[#07101a] px-3 py-2.5 text-sm text-white outline-none placeholder:text-slate-500 focus:border-[var(--color-red)]"
  : "mt-1 w-full rounded-[4px] border border-slate-200 bg-white px-3 py-2.5 text-sm text-[var(--color-ink)] outline-none placeholder:text-slate-400 focus:border-[var(--color-red)]";
const titleClass = isDark ? "text-white" : "text-[var(--color-ink)]";
const textClass = isDark ? "text-slate-400" : "text-slate-600";
---

<form
  class={panelClass}
  data-inquiry-form
  data-track="submit_inquiry_form"
  data-success={copy.success}
  data-error={copy.error}
  data-sending={copy.sending}
  data-inquiry-tone={tone}
>
  <input type="hidden" name="lang" value={lang} />
  <input type="hidden" name="source" value="" data-inquiry-source />
  <label style="position:absolute;left:-5000px;top:auto;width:1px;height:1px;overflow:hidden;">
    Website
    <input type="text" name="website" tabindex="-1" autocomplete="off" />
  </label>

  <div>
    <h3 class={`text-lg font-semibold ${titleClass}`}>{copy.title}</h3>
    <p class={`mt-2 text-sm leading-6 ${textClass}`}>{copy.lead}</p>
  </div>

  <div class="mt-4 grid gap-3 sm:grid-cols-2">
    <label class={`text-xs font-semibold ${labelClass}`}>
      {copy.name}
      <input class={inputClass} name="name" type="text" autocomplete="name" placeholder={copy.namePlaceholder} required />
    </label>
    <label class={`text-xs font-semibold ${labelClass}`}>
      {copy.country}
      <input class={inputClass} name="country" type="text" autocomplete="country-name" placeholder={copy.countryPlaceholder} required />
    </label>
    <label class={`text-xs font-semibold ${labelClass}`}>
      {copy.contact}
      <input class={inputClass} name="contact" type="text" autocomplete="email" placeholder={copy.contactPlaceholder} required />
    </label>
  </div>

  <label class={`mt-3 block text-xs font-semibold ${labelClass}`}>
    {copy.message}
    <textarea class={`${inputClass} min-h-28 resize-y`} name="message" placeholder={copy.messagePlaceholder} required></textarea>
  </label>

  <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p class={`text-xs leading-5 ${textClass}`}>{copy.note}</p>
    <button type="submit" class="shrink-0 rounded-[4px] bg-[var(--color-red)] px-4 py-3 text-sm font-semibold text-white">
      {copy.submit}
    </button>
  </div>
  <p class="mt-3 hidden rounded-[4px] px-3 py-2 text-sm font-semibold" data-inquiry-status></p>
</form>

<script is:inline>
  if (!window.__LIJIAN_INQUIRY_FORM__) {
    window.__LIJIAN_INQUIRY_FORM__ = true;

    const setStatus = (form, message, state) => {
      const status = form.querySelector("[data-inquiry-status]");
      if (!status) return;
      const isLight = form.dataset.inquiryTone === "light";
      status.textContent = message;
      status.classList.remove(
        "hidden",
        "bg-red-500/15",
        "text-red-100",
        "bg-green-500/15",
        "text-green-100",
        "bg-red-50",
        "text-red-700",
        "bg-green-50",
        "text-green-700",
        "bg-slate-100",
        "text-slate-700"
      );
      if (state === "success") {
        status.classList.add(isLight ? "bg-green-50" : "bg-green-500/15", isLight ? "text-green-700" : "text-green-100");
      } else if (state === "error") {
        status.classList.add(isLight ? "bg-red-50" : "bg-red-500/15", isLight ? "text-red-700" : "text-red-100");
      } else {
        status.classList.add("bg-slate-100", "text-slate-700");
      }
    };

    document.addEventListener("submit", async (event) => {
      const form = event.target instanceof Element ? event.target.closest("[data-inquiry-form]") : null;
      if (!form) return;
      event.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]');
      const originalButtonText = submitButton ? submitButton.textContent : "";
      const source = form.querySelector("[data-inquiry-source]");
      if (source) source.value = window.location.href;

      const payload = Object.fromEntries(new FormData(form).entries());
      submitButton && (submitButton.disabled = true);
      submitButton && (submitButton.textContent = form.dataset.sending || "Sending...");
      setStatus(form, form.dataset.sending || "Sending...", "pending");

      try {
        const response = await fetch("/api/inquiry", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (!response.ok) throw new Error("Request failed");

        form.reset();
        if (source) source.value = window.location.href;
        setStatus(form, form.dataset.success || "Sent.", "success");
        if (typeof window.trackSiteEvent === "function") {
          window.trackSiteEvent("inquiry_form_sent", {
            event_category: "lead",
            label: payload.name || "",
            country: payload.country || "",
            language: payload.lang || document.documentElement.lang || "",
            source: payload.source || window.location.href,
          });
          window.trackSiteEvent("generate_lead", {
            event_category: "conversion",
            method: "inquiry_form",
            country: payload.country || "",
            language: payload.lang || document.documentElement.lang || "",
          });
        }
      } catch {
        setStatus(form, form.dataset.error || "Could not send.", "error");
      } finally {
        submitButton && (submitButton.disabled = false);
        submitButton && (submitButton.textContent = originalButtonText);
      }
    });
  }
</script>
