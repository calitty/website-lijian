const attachmentCopy = attachmentCopyByLang[lang as keyof typeof attachmentCopyByLang] ?? attachmentCopyByLang.en;
const fieldStateCopyByLang = {
  en: { required: "Required", optional: "Optional" },
  ru: { required: "Обязательно", optional: "Необязательно" },
  ar: { required: "مطلوب", optional: "اختياري" },
  es: { required: "Obligatorio", optional: "Opcional" },
  pt: { required: "Obrigatório", optional: "Opcional" },
  tr: { required: "Zorunlu", optional: "Opsiyonel" },
  de: { required: "Pflichtfeld", optional: "Optional" },
  fr: { required: "Requis", optional: "Facultatif" },
  it: { required: "Obbligatorio", optional: "Opzionale" },
  th: { required: "จำเป็น", optional: "ไม่บังคับ" },
  vi: { required: "Bắt buộc", optional: "Không bắt buộc" },
  id: { required: "Wajib", optional: "Opsional" },
  zh: { required: "必填", optional: "选填" },
} as const;
const fieldState = fieldStateCopyByLang[lang as keyof typeof fieldStateCopyByLang] ?? fieldStateCopyByLang.en;

const isDark = tone === "dark";
const isCompact = variant === "compact";
const panelClass = isCompact
  ? "w-[min(calc(100vw-2rem),25rem)] rounded-[8px] border border-slate-200 bg-white p-4 shadow-[0_24px_60px_rgba(8,15,25,.28)]"
  : isDark
    ? "rounded-[6px] border border-white/10 bg-[#0b1520] p-4"
    : "rounded-[8px] border border-[var(--color-border)] bg-white p-5 shadow-[0_10px_30px_rgba(9,42,94,.06)]";
const labelClass = isDark ? "text-slate-300" : "text-slate-700";
const inputClass = isDark
  ? "mt-1 w-full rounded-[4px] border border-white/10 bg-[#07101a] px-3 py-2.5 text-sm text-white outline-none placeholder:text-slate-500 focus:border-[#8ecae6]"
  : "mt-1 w-full rounded-[4px] border border-[#d5e2f4] bg-white px-3 py-2.5 text-sm text-[var(--color-ink)] outline-none placeholder:text-slate-400 focus:border-[var(--color-blue)]";
const titleClass = isDark ? "text-white" : "text-[var(--color-ink)]";
const textClass = isDark ? "text-slate-400" : "text-slate-600";
const requiredBadgeClass = isDark
  ? "ms-2 inline-flex rounded-[4px] border border-white/15 px-1.5 py-0.5 text-[10px] font-semibold text-slate-200"
  : "ms-2 inline-flex rounded-[4px] bg-[var(--color-blue)] px-1.5 py-0.5 text-[10px] font-semibold text-white";
const optionalBadgeClass = isDark
  ? "ms-2 inline-flex rounded-[4px] border border-white/15 px-1.5 py-0.5 text-[10px] font-semibold text-slate-300"
  : "ms-2 inline-flex rounded-[4px] border border-slate-200 bg-slate-50 px-1.5 py-0.5 text-[10px] font-semibold text-slate-500";
---

{
  isCompact ? (
    <form
      class={panelClass}
      data-inquiry-form
      data-success={copy.success}
      data-error={copy.error}
      data-sending={copy.sending}
      data-file-error={attachmentCopy.tooLarge}
      data-inquiry-tone="light"
    >
      <input type="hidden" name="lang" value={lang} />
      <input type="hidden" name="source" value="" data-inquiry-source />
      <label style="position:absolute;left:0;top:0;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);clip-path:inset(50%);white-space:nowrap;opacity:0;pointer-events:none;">
        Website
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </label>

      <div>
        <h3 class="text-base font-semibold text-[var(--color-ink)]">{copy.title}</h3>
        <p class="mt-1.5 text-xs leading-5 text-slate-600">{copy.lead}</p>
      </div>

	      <div class="mt-3 grid gap-2">
	        <label class="text-xs font-semibold text-slate-700">
	          <span>{copy.name}<span class={requiredBadgeClass}>{fieldState.required}</span></span>
	          <input class={inputClass} name="name" type="text" autocomplete="name" placeholder={copy.namePlaceholder} required />
	        </label>
	        <div class="grid gap-2 sm:grid-cols-2">
	          <label class="text-xs font-semibold text-slate-700">
	            <span>{copy.country}<span class={requiredBadgeClass}>{fieldState.required}</span></span>
	            <input class={inputClass} name="country" type="text" autocomplete="country-name" placeholder={copy.countryPlaceholder} required />
	          </label>
	          <label class="text-xs font-semibold text-slate-700">
	            <span>{copy.contact}<span class={requiredBadgeClass}>{fieldState.required}</span></span>
	            <input class={inputClass} name="contact" type="text" autocomplete="email" placeholder={copy.contactPlaceholder} required />
	          </label>
	        </div>
	        <label class="text-xs font-semibold text-slate-700">
	          <span>{copy.message}<span class={requiredBadgeClass}>{fieldState.required}</span></span>
	          <textarea class={`${inputClass} min-h-24 resize-y`} name="message" placeholder={copy.messagePlaceholder} required></textarea>
	        </label>
	        <label class="text-xs font-semibold text-slate-700">
	          <span>{attachmentCopy.label}<span class={optionalBadgeClass}>{fieldState.optional}</span></span>
	          <input
	            class={inputClass}
            name="attachment"
            type="file"
            accept=".pdf,.jpg,.jpeg,.png,.webp,.dwg,.dxf,.step,.stp,.zip,.rar"
            data-inquiry-attachment
          />
          <span class="mt-1 block text-[11px] font-medium leading-4 text-slate-500">{attachmentCopy.hint}</span>
        </label>
      </div>

      <button type="submit" class="mt-3 w-full rounded-[4px] bg-[var(--color-blue)] px-4 py-3 text-sm font-semibold text-white">
        {copy.submit}
      </button>
      <p class="mt-3 hidden rounded-[4px] px-3 py-2 text-xs font-semibold" data-inquiry-status role="status" aria-live="polite"></p>
    </form>
  ) : (
    <form
      class={panelClass}
      data-inquiry-form
      data-success={copy.success}
      data-error={copy.error}
      data-sending={copy.sending}
      data-file-error={attachmentCopy.tooLarge}
      data-inquiry-tone={tone}
    >
      <input type="hidden" name="lang" value={lang} />
      <input type="hidden" name="source" value="" data-inquiry-source />
      <label style="position:absolute;left:0;top:0;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);clip-path:inset(50%);white-space:nowrap;opacity:0;pointer-events:none;">
        Website
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </label>

      <div>
        <h3 class={`text-lg font-semibold ${titleClass}`}>{copy.title}</h3>
        <p class={`mt-2 text-sm leading-6 ${textClass}`}>{copy.lead}</p>
      </div>

	      <div class="mt-4 grid gap-3 sm:grid-cols-2">
	        <label class={`text-xs font-semibold ${labelClass}`}>
	          <span>{copy.name}<span class={requiredBadgeClass}>{fieldState.required}</span></span>
	          <input class={inputClass} name="name" type="text" autocomplete="name" placeholder={copy.namePlaceholder} required />
	        </label>
	        <label class={`text-xs font-semibold ${labelClass}`}>
	          <span>{copy.country}<span class={requiredBadgeClass}>{fieldState.required}</span></span>
	          <input class={inputClass} name="country" type="text" autocomplete="country-name" placeholder={copy.countryPlaceholder} required />
	        </label>
	        <label class={`text-xs font-semibold ${labelClass}`}>
	          <span>{copy.contact}<span class={requiredBadgeClass}>{fieldState.required}</span></span>
	          <input class={inputClass} name="contact" type="text" autocomplete="email" placeholder={copy.contactPlaceholder} required />
	        </label>
	      </div>

	      <label class={`mt-3 block text-xs font-semibold ${labelClass}`}>
	        <span>{copy.message}<span class={requiredBadgeClass}>{fieldState.required}</span></span>
	        <textarea class={`${inputClass} min-h-28 resize-y`} name="message" placeholder={copy.messagePlaceholder} required></textarea>
	      </label>

	      <label class={`mt-3 block text-xs font-semibold ${labelClass}`}>
	        <span>{attachmentCopy.label}<span class={optionalBadgeClass}>{fieldState.optional}</span></span>
	        <input
          class={inputClass}
          name="attachment"
          type="file"
          accept=".pdf,.jpg,.jpeg,.png,.webp,.dwg,.dxf,.step,.stp,.zip,.rar"
          data-inquiry-attachment
        />
        <span class={`mt-1 block text-[11px] font-medium leading-4 ${textClass}`}>{attachmentCopy.hint}</span>
      </label>

      <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <p class={`text-xs leading-5 ${textClass}`}>{copy.note}</p>
        <button type="submit" class="shrink-0 rounded-[4px] bg-[var(--color-blue)] px-4 py-3 text-sm font-semibold text-white">
          {copy.submit}
        </button>
      </div>
      <p class="mt-3 hidden rounded-[4px] px-3 py-2 text-sm font-semibold" data-inquiry-status role="status" aria-live="polite"></p>
    </form>
  )
}

<script is:inline>
  if (!window.__LIJIAN_INQUIRY_FORM__) {
    window.__LIJIAN_INQUIRY_FORM__ = true;

    const setStatus = (form, message, state) => {
      const status = form.querySelector("[data-inquiry-status]");
      if (!status) return;
      const isLight = form.dataset.inquiryTone === "light";
      status.textContent = message;
      status.classList.remove(
        "hidden",
        "bg-red-500/15",
        "text-red-100",
        "bg-green-500/15",
        "text-green-100",
        "bg-red-50",
        "text-red-700",
        "bg-green-50",
        "text-green-700",
        "bg-slate-100",
        "text-slate-700"
      );
      if (state === "error") {
        status.setAttribute("role", "alert");
        status.setAttribute("aria-live", "assertive");
      } else {
        status.setAttribute("role", "status");
        status.setAttribute("aria-live", "polite");
      }
      if (state === "success") {
        status.classList.add(isLight ? "bg-green-50" : "bg-green-500/15", isLight ? "text-green-700" : "text-green-100");
      } else if (state === "error") {
        status.classList.add(isLight ? "bg-red-50" : "bg-red-500/15", isLight ? "text-red-700" : "text-red-100");
      } else {
        status.classList.add("bg-slate-100", "text-slate-700");
      }
    };

    const maxAttachmentSize = 6 * 1024 * 1024;
    const maxAttachmentTotal = 10 * 1024 * 1024;
    const maxAttachmentCount = 3;

    const fileToAttachment = (file) =>
      new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => {
          const result = String(reader.result || "");
          resolve({
            filename: file.name,
            contentType: file.type || "application/octet-stream",
            content: result.includes(",") ? result.split(",").pop() : result,
          });
        };
        reader.onerror = () => reject(reader.error || new Error("File read failed"));
        reader.readAsDataURL(file);
      });

    const buildPayload = async (form) => {
      const formData = new FormData(form);
      const payload = {};
      formData.forEach((value, key) => {
        if (typeof File !== "undefined" && value instanceof File) return;
        payload[key] = value;
      });

      const files = Array.from(form.querySelectorAll("[data-inquiry-attachment]"))
        .flatMap((input) => Array.from(input.files || []))
        .filter((file) => file.size > 0);
      const totalSize = files.reduce((sum, file) => sum + file.size, 0);
      const hasOversizeFile = files.some((file) => file.size > maxAttachmentSize);
      if (files.length > maxAttachmentCount || totalSize > maxAttachmentTotal || hasOversizeFile) {
        throw new Error("Attachment too large");
      }
      if (files.length) {
        payload.attachments = await Promise.all(files.map(fileToAttachment));
      }
      return payload;
    };

    document.addEventListener("submit", async (event) => {
      const form = event.target instanceof Element ? event.target.closest("[data-inquiry-form]") : null;
      if (!form) return;
      event.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]');
      const originalButtonText = submitButton ? submitButton.textContent : "";
      const source = form.querySelector("[data-inquiry-source]");
      if (source) source.value = window.location.href;

      let payload = {};
      submitButton && (submitButton.disabled = true);
      submitButton && (submitButton.textContent = form.dataset.sending || "Sending...");
      setStatus(form, form.dataset.sending || "Sending...", "pending");
      if (typeof window.trackSiteEvent === "function") {
        window.trackSiteEvent("submit_inquiry_form", {
          event_category: "lead",
          label: form.getAttribute("data-track-label") || "",
          language: document.documentElement.lang || "",
          source: window.location.href,
        });
      }

      try {
        payload = await buildPayload(form);
        const response = await fetch("/api/inquiry", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (!response.ok) throw new Error("Request failed");

        form.reset();
        if (source) source.value = window.location.href;
        setStatus(form, form.dataset.success || "Sent.", "success");
        if (typeof window.trackSiteEvent === "function") {
          window.trackSiteEvent("inquiry_form_sent", {
            event_category: "lead",
            label: payload.name || "",
            country: payload.country || "",
            language: payload.lang || document.documentElement.lang || "",
            source: payload.source || window.location.href,
          });
          window.trackSiteEvent("submit_contact_form", {
            event_category: "lead",
            label: payload.name || "",
            country: payload.country || "",
            language: payload.lang || document.documentElement.lang || "",
            source: payload.source || window.location.href,
          });
          window.trackSiteEvent("generate_lead", {
            event_category: "conversion",
            method: "inquiry_form",
            country: payload.country || "",
            language: payload.lang || document.documentElement.lang || "",
          });
        }
      } catch (error) {
        const isAttachmentError = error instanceof Error && error.message === "Attachment too large";
        setStatus(form, isAttachmentError ? form.dataset.fileError || form.dataset.error || "Could not send." : form.dataset.error || "Could not send.", "error");
        if (typeof window.trackSiteEvent === "function") {
          window.trackSiteEvent("inquiry_form_error", {
            event_category: "lead",
            error_type: isAttachmentError ? "attachment_too_large" : "request_failed",
            language: document.documentElement.lang || "",
            source: window.location.href,
          });
        }
      } finally {
        submitButton && (submitButton.disabled = false);
        submitButton && (submitButton.textContent = originalButtonText);
      }
    });
  }
</script>
