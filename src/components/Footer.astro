---

<footer class="border-t border-white/10 bg-[#070b10] pb-24 text-white sm:pb-12">
  <div class="container-page grid gap-9 py-12 lg:grid-cols-[1.35fr_.72fr_.72fr_1.05fr]">
    <div>
      <div class="flex items-center gap-3">
        <span class="grid h-11 w-11 shrink-0 place-items-center overflow-hidden rounded-[4px] bg-white p-1.5">
          <img src={contact.logo} alt="" class="h-full w-full object-contain" loading="lazy" />
        </span>
        <span>
          <p class="text-lg font-semibold">{t.siteName}</p>
          <p class="mt-1 text-xs font-semibold uppercase tracking-[.14em] text-slate-400">Food Machine Blades</p>
        </span>
      </div>
      <p class="mt-4 text-sm font-semibold uppercase text-[var(--color-silver)]">{footerCopy.tagline}</p>
      <p class="mt-4 max-w-md text-sm leading-7 text-slate-300">{footerCopy.summary}</p>
      <div class="mt-5 flex flex-wrap gap-x-4 gap-y-2 text-xs font-semibold text-slate-400">
        {footerCopy.badges.map((item) => (
          <span>{item}</span>
        ))}
      </div>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase text-slate-400">{footerCopy.productsTitle}</p>
      <div class="mt-4 grid gap-2.5 text-sm text-slate-300">
        {footerProducts.map(([label, href]) => (
          <a href={withLang(lang, href)} class="hover:text-white">{label}</a>
        ))}
      </div>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase text-slate-400">{footerCopy.applicationsTitle}</p>
      <div class="mt-4 grid gap-2.5 text-sm text-slate-300">
        {footerApplications.map(([label, href]) => (
          <a href={withLang(lang, href)} class="hover:text-white">{label}</a>
        ))}
      </div>
      <p class="mt-6 text-sm font-semibold uppercase text-slate-400">{footerCopy.buyerTitle}</p>
      <p class="mt-4 text-sm leading-7 text-slate-300">{footerCopy.inquiryHint}</p>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase text-slate-400">{footerCopy.contactTitle}</p>
      <div class="mt-4 grid gap-2.5 text-sm text-slate-300">
        <a href={channelLinks.whatsapp} class="font-semibold text-white hover:text-[var(--color-silver)]" data-track="click_whatsapp">
          {footerCopy.whatsapp}: {contact.whatsapp}
        </a>
        <a href={channelLinks.email} class="break-all hover:text-white" data-track="click_email">
          {contact.email}
        </a>
        <div class="mt-4 border-t border-white/10 pt-4">
          <p class="text-xs font-semibold uppercase text-slate-500">{footerCopy.officeTitle}</p>
          <div class="mt-3 grid gap-3">
            {contact.departments.map((department) => (
              <div class="grid gap-1">
                <span class="font-semibold text-slate-100">{department.name[lang]}</span>
                <a class="text-sm text-slate-300 hover:text-white" href={`tel:${department.phone.replace(/\s/g, "")}`} data-track="click_phone" data-track-label={department.id}>{department.phone}</a>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="container-page flex flex-col gap-2 border-t border-white/10 pt-6 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between">
    <span>© {year} {contact.company[lang]}.</span>
    <span>{footerCopy.copyright}</span>
  </div>
</footer>
