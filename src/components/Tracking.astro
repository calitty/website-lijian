---
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const yandexId = import.meta.env.PUBLIC_YANDEX_METRICA_ID;
const clarityId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID;
---

{gaId && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
    <script is:inline define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", gaId);
    </script>
  </>
)}

{yandexId && (
  <script is:inline define:vars={{ yandexId }}>
    (function(m,e,t,r,i,k,a){
      m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
      m[i].l=1*new Date();
      k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
    })(window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
    ym(Number(yandexId), "init", { clickmap:true, trackLinks:true, accurateTrackBounce:true });
    window.__YANDEX_METRICA_ID__ = Number(yandexId);
  </script>
)}

{clarityId && (
  <script is:inline define:vars={{ clarityId }}>
    (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", clarityId);
  </script>
)}

<script is:inline>
  const getPageContext = () => ({
    page_location: window.location.href,
    page_path: window.location.pathname,
    page_title: document.title,
    page_language: document.documentElement.lang || "",
    hostname: window.location.hostname,
  });

  const sendTrackedEvent = (name, params = {}) => {
    if (!name) return;
    const payload = { ...getPageContext(), ...params };
    if (typeof window.gtag === "function") {
      window.gtag("event", name, payload);
    }
    if (typeof window.ym === "function" && window.__YANDEX_METRICA_ID__) {
      window.ym(window.__YANDEX_METRICA_ID__, "reachGoal", name, payload);
    }
    window.dispatchEvent(new CustomEvent("site:analytics", { detail: { name, params: payload } }));
  };
  window.trackSiteEvent = sendTrackedEvent;

  document.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target.closest("[data-track]") : null;
    if (!target) return;
    sendTrackedEvent(target.getAttribute("data-track"), {
      event_category: "engagement",
      label: target.getAttribute("data-track-label") || target.textContent?.trim() || "",
      link_url: target.getAttribute("href") || "",
      link_text: target.textContent?.trim() || "",
    });
  });

  document.addEventListener("submit", (event) => {
    const form = event.target instanceof Element ? event.target.closest("form[data-track]") : null;
    if (!form) return;
    sendTrackedEvent(form.getAttribute("data-track"), {
      event_category: "lead",
      label: form.getAttribute("data-track-label") || "",
    });
  });

  let scrolled90 = false;
  const onScroll = () => {
    if (scrolled90) return;
    const scrollable = document.documentElement.scrollHeight - window.innerHeight;
    if (scrollable <= 0) return;
    const progress = (window.scrollY / scrollable) * 100;
    if (progress >= 90) {
      scrolled90 = true;
      sendTrackedEvent("scroll_90_percent", { event_category: "engagement" });
      window.removeEventListener("scroll", onScroll);
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
