---
import Img from "@/components/Img.astro";
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  image: string;
  imageAlt: string;
}

const { eyebrow, title, lead, image, imageAlt } = Astro.props;
const imageWebp = image.replace(/\.(jpe?g|png)$/i, ".webp");
---

<section
  class="relative overflow-hidden bg-[var(--color-ink)] py-16 text-white md:py-20"
  style={`background-image: linear-gradient(90deg, rgba(7,11,16,.98), rgba(7,11,16,.86) 48%, rgba(7,11,16,.44)), url('${image}'); background-image: linear-gradient(90deg, rgba(7,11,16,.98), rgba(7,11,16,.86) 48%, rgba(7,11,16,.44)), image-set(url('${imageWebp}') type('image/webp'), url('${image}')); background-size: cover; background-position: center;`}
>
  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,.04),rgba(0,0,0,.36))]"></div>
  <div class="absolute inset-x-0 bottom-0 h-px bg-white/15"></div>
  <div class="container-page relative grid gap-10 lg:grid-cols-[1fr_.82fr] lg:items-center">
    <div>
      <p class="text-sm font-semibold uppercase text-[var(--color-silver)]">{eyebrow}</p>
      <h1 class="mt-4 max-w-4xl text-4xl font-semibold leading-tight md:text-5xl">{title}</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">{lead}</p>
      <slot />
    </div>
    <Img src={image} alt={imageAlt} class="aspect-[4/3] w-full rounded-[6px] border border-white/12 object-cover" loading="eager" fetchpriority="high" />
  </div>
</section>
