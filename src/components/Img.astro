---
// Serves a WebP version (generated by scripts/generate-webp.mjs) with the
// original raster file as a guaranteed fallback. `display:contents` keeps the
// <picture> transparent to layout so the <img>'s own classes behave unchanged.
type Props = {
  src: string;
  alt: string;
  class?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  decoding?: "async" | "sync" | "auto";
  width?: number | string;
  height?: number | string;
};
const { src, alt, class: className, ...rest } = Astro.props;
const webp = src.replace(/\.(jpe?g|png)$/i, ".webp");
const hasWebp = webp !== src;
---

{
  hasWebp ? (
    <picture style="display:contents">
      <source srcset={webp} type="image/webp" />
      <img src={src} alt={alt} class={className} {...rest} />
    </picture>
  ) : (
    <img src={src} alt={alt} class={className} {...rest} />
  )
}
