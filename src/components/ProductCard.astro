---
import { localize, localizeList, localizeTerm, ui, withLang, type Lang } from "@/data/site";

interface Product {
  slug: string;
  image: string;
  tags: readonly string[];
  name: { readonly en: string } & Partial<Record<Lang, string>>;
  summary: { readonly en: string } & Partial<Record<Lang, string>>;
  applications: readonly string[];
  equipment: readonly string[];
  customOptions: { readonly en: readonly string[] } & Partial<Record<Lang, readonly string[]>>;
}

interface Props {
  product: Product;
  lang: Lang;
  contactHref?: string;
  useHomeJump?: boolean;
}

const { product, lang, contactHref = `${withLang(lang)}#contact`, useHomeJump = contactHref.startsWith("#") } = Astro.props;
const t = ui[lang];
const formatApplication = (item: string) => localizeTerm(item, lang);
const formatEquipment = (item: string) => localizeTerm(item, lang);
const cardCopyByLang = {
  en: { equipment: "Equipment", custom: "Custom" },
  ru: { equipment: "Оборудование", custom: "Параметры" },
  ar: { equipment: "المعدات", custom: "تخصيص" },
  es: { equipment: "Equipo", custom: "A medida" },
  pt: { equipment: "Equipamento", custom: "Sob medida" },
  tr: { equipment: "Ekipman", custom: "Özel" },
  de: { equipment: "Maschine", custom: "Anpassung" },
  fr: { equipment: "Équipement", custom: "Sur mesure" },
  it: { equipment: "Macchina", custom: "Su misura" },
  th: { equipment: "อุปกรณ์", custom: "สั่งผลิต" },
  vi: { equipment: "Thiết bị", custom: "Tùy chỉnh" },
  id: { equipment: "Peralatan", custom: "Kustom" },
  zh: { equipment: "适配设备", custom: "可定制" },
} as const;
const cardCopy = cardCopyByLang[lang as keyof typeof cardCopyByLang] ?? cardCopyByLang.en;
---

<article class="flex h-full flex-col overflow-hidden rounded-[6px] border border-slate-200 bg-white shadow-sm">
  <div class="relative overflow-hidden bg-slate-100">
    <img
      src={product.image}
      alt={localize(product.name, lang)}
      class="aspect-[4/3] w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-black/58 to-transparent"></div>
    <div class="absolute bottom-4 left-4 right-4 flex flex-wrap gap-2">
      {product.tags.slice(0, 2).map((tag) => (
        <span class="rounded-[4px] border border-white/20 bg-white/90 px-2.5 py-1 text-xs font-semibold text-slate-800 shadow-sm">{localizeTerm(tag, lang)}</span>
      ))}
    </div>
  </div>
  <div class="flex flex-1 flex-col p-5">
    <div class="mb-4 flex flex-wrap gap-2">
      {product.applications.slice(0, 3).map((item) => (
        <span class="rounded-[4px] bg-[var(--color-mist)] px-2.5 py-1 text-xs font-semibold text-slate-600">{formatApplication(item)}</span>
      ))}
    </div>
    <h3 class="text-xl font-semibold leading-snug text-[var(--color-ink)]">{localize(product.name, lang)}</h3>
    <p class="mt-3 flex-1 text-sm leading-7 text-slate-600">{localize(product.summary, lang)}</p>

    <div class="mt-5 grid gap-3 border-t border-slate-100 pt-5">
      <div>
        <p class="text-xs font-semibold uppercase text-slate-400">{cardCopy.equipment}</p>
        <p class="mt-1 text-sm font-semibold leading-6 text-slate-700">{product.equipment.slice(0, 2).map(formatEquipment).join(" / ")}</p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase text-slate-400">{cardCopy.custom}</p>
        <div class="mt-2 flex flex-wrap gap-2">
          {localizeList(product.customOptions, lang).slice(0, 3).map((item) => (
            <span class="rounded-[4px] border border-slate-200 px-2.5 py-1 text-xs font-semibold text-slate-600">{item}</span>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-6 flex justify-end border-t border-slate-100 pt-4">
      <a
        href={contactHref}
        class="rounded-[4px] bg-[var(--color-red)] px-3.5 py-2 text-xs font-semibold text-white"
        data-track="click_contact_from_product"
        data-track-label={product.slug}
        data-home-jump={useHomeJump ? "contact" : undefined}
      >
        {t.actions.discussBlade}
      </a>
    </div>
  </div>
</article>
