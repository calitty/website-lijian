---
import Img from "@/components/Img.astro";
import { localize, localizeList, localizeTerm, ui, withLang, type Lang } from "@/data/site";

interface Product {
  slug: string;
  image: string;
  tags: readonly string[];
  name: { readonly en: string } & Partial<Record<Lang, string>>;
  summary: { readonly en: string } & Partial<Record<Lang, string>>;
  applications: readonly string[];
  equipment: readonly string[];
  customOptions: { readonly en: readonly string[] } & Partial<Record<Lang, readonly string[]>>;
}

interface Props {
  product: Product;
  lang: Lang;
  contactHref?: string;
  detailHref?: string;
  useHomeJump?: boolean;
  variant?: "full" | "catalog";
}

const {
  product,
  lang,
  contactHref = `${withLang(lang)}#contact`,
  detailHref = withLang(lang, `/products/${product.slug}`),
  useHomeJump = contactHref.startsWith("#"),
  variant = "full",
} = Astro.props;
const t = ui[lang];
const isCatalog = variant === "catalog";
const formatApplication = (item: string) => localizeTerm(item, lang);
const formatEquipment = (item: string) => localizeTerm(item, lang);
const cardCopyByLang = {
  en: { equipment: "Equipment", custom: "Custom", details: "Details" },
  ru: { equipment: "Оборудование", custom: "Параметры", details: "Подробнее" },
  ar: { equipment: "المعدات", custom: "تخصيص", details: "التفاصيل" },
  es: { equipment: "Equipo", custom: "A medida", details: "Detalles" },
  pt: { equipment: "Equipamento", custom: "Sob medida", details: "Detalhes" },
  tr: { equipment: "Ekipman", custom: "Özel", details: "Detaylar" },
  de: { equipment: "Maschine", custom: "Anpassung", details: "Details" },
  fr: { equipment: "Équipement", custom: "Sur mesure", details: "Détails" },
  it: { equipment: "Macchina", custom: "Su misura", details: "Dettagli" },
  th: { equipment: "อุปกรณ์", custom: "สั่งผลิต", details: "รายละเอียด" },
  vi: { equipment: "Thiết bị", custom: "Tùy chỉnh", details: "Chi tiết" },
  id: { equipment: "Peralatan", custom: "Kustom", details: "Detail" },
  zh: { equipment: "适配设备", custom: "可定制", details: "查看详情" },
} as const;
const cardCopy = cardCopyByLang[lang as keyof typeof cardCopyByLang] ?? cardCopyByLang.en;
---

{isCatalog ? (
  <article class="group flex h-full flex-col overflow-hidden rounded-[8px] border border-[var(--color-border)] bg-white shadow-[0_10px_30px_rgba(9,42,94,.06)] transition duration-200 hover:-translate-y-0.5 hover:border-[#b9cceb] hover:shadow-[0_18px_42px_rgba(9,42,94,.12)]">
    <a href={detailHref} class="block bg-gradient-to-b from-white to-[#f4f8fd] px-4 pt-4" data-track="click_product_detail" data-track-label={product.slug}>
      <Img
        src={product.image}
        alt={localize(product.name, lang)}
        class="aspect-[4/3] w-full object-contain transition duration-300 group-hover:scale-[1.03]"
        loading="lazy"
      />
    </a>
    <div class="flex flex-1 flex-col p-3.5 sm:p-4">
      <h3 class="text-base font-semibold leading-6 text-[var(--color-ink)] group-hover:text-[var(--color-blue)]">{localize(product.name, lang)}</h3>
      <p class="mt-2 overflow-hidden text-sm leading-6 text-slate-600 [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:2]">{localize(product.summary, lang)}</p>
      <div class="mt-3 grid gap-1.5 border-t border-[var(--color-border)] pt-3">
        <p class="overflow-hidden text-xs font-semibold leading-5 text-slate-700 [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:1]">{product.equipment.slice(0, 2).map(formatEquipment).join(" / ")}</p>
        <p class="overflow-hidden text-xs font-semibold leading-5 text-[var(--color-blue)] [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:1]">{localizeList(product.customOptions, lang).slice(0, 2).join(" / ")}</p>
      </div>
      <div class="mt-auto flex items-center justify-between gap-2 pt-4 sm:gap-3">
        <a
          href={contactHref}
          class="rounded-[4px] border border-[#c5d7ef] bg-white px-2.5 py-2 text-xs font-semibold text-[var(--color-blue)] hover:border-[var(--color-blue)] hover:bg-[var(--color-blue-soft)] sm:px-3"
          data-track="click_contact_from_product"
          data-track-label={product.slug}
          data-home-jump={useHomeJump ? "contact" : undefined}
        >
          {t.actions.discussBlade}
        </a>
        <a
          href={detailHref}
          class="grid h-8 w-8 shrink-0 place-items-center rounded-full border border-[#c5d7ef] text-sm font-semibold text-[var(--color-blue)] hover:border-[var(--color-blue)] hover:bg-[var(--color-blue-soft)]"
          aria-label={cardCopy.details}
          data-track="click_product_detail"
          data-track-label={product.slug}
        >
          <span aria-hidden="true" class="inline-block rtl:rotate-180">→</span>
        </a>
      </div>
    </div>
  </article>
) : (
  <article class="group flex h-full flex-col overflow-hidden rounded-[8px] border border-[var(--color-border)] bg-white shadow-[0_10px_30px_rgba(9,42,94,.06)] transition duration-200 hover:-translate-y-0.5 hover:border-[#b9cceb] hover:shadow-[0_18px_42px_rgba(9,42,94,.12)]">
    <div class="relative overflow-hidden bg-gradient-to-b from-white to-[#f4f8fd] px-4 pt-4">
      <Img
        src={product.image}
        alt={localize(product.name, lang)}
        class="aspect-[4/3] w-full object-contain transition duration-300 group-hover:scale-[1.03]"
        loading="lazy"
      />
    </div>
    <div class="flex flex-1 flex-col p-4">
      <div class="mb-3 flex flex-wrap gap-2">
        {product.tags.slice(0, 2).map((tag) => (
          <span class="rounded-[4px] border border-[#d9e6f7] bg-[var(--color-blue-soft)] px-2.5 py-1 text-[11px] font-semibold leading-4 text-[var(--color-blue)]">{localizeTerm(tag, lang)}</span>
        ))}
      </div>
      <h3 class="text-base font-semibold leading-6 text-[var(--color-ink)] group-hover:text-[var(--color-blue)]">{localize(product.name, lang)}</h3>
      <p class="mt-2 flex-1 overflow-hidden text-sm leading-6 text-slate-600 [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:3]">{localize(product.summary, lang)}</p>

      <div class="mt-4 grid gap-3 border-t border-[var(--color-border)] pt-4">
        <div>
          <p class="text-[11px] font-semibold uppercase text-slate-400">{cardCopy.equipment}</p>
          <p class="mt-1 text-xs font-semibold leading-5 text-slate-700">{product.equipment.slice(0, 2).map(formatEquipment).join(" / ")}</p>
        </div>
        <div>
          <p class="text-[11px] font-semibold uppercase text-slate-400">{cardCopy.custom}</p>
          <div class="mt-2 flex flex-wrap gap-2">
            {product.applications.slice(0, 2).map((item) => (
              <span class="rounded-[4px] bg-[var(--color-mist)] px-2.5 py-1 text-[11px] font-semibold leading-4 text-slate-600">{formatApplication(item)}</span>
            ))}
            {localizeList(product.customOptions, lang).slice(0, 1).map((item) => (
              <span class="rounded-[4px] border border-[var(--color-border)] bg-white px-2.5 py-1 text-[11px] font-semibold leading-4 text-slate-600">{item}</span>
            ))}
          </div>
        </div>
      </div>

      <div class="mt-5 flex flex-wrap items-center justify-between gap-3 border-t border-[var(--color-border)] pt-4">
        <a
          href={detailHref}
          class="inline-flex items-center gap-2 rounded-[4px] border border-[#c5d7ef] bg-white px-3 py-2 text-xs font-semibold text-[var(--color-blue)] hover:border-[var(--color-blue)] hover:bg-[var(--color-blue-soft)]"
          data-track="click_product_detail"
          data-track-label={product.slug}
        >
          {cardCopy.details}
          <span aria-hidden="true" class="inline-block rtl:rotate-180">→</span>
        </a>
        <a
          href={contactHref}
          class="rounded-[4px] bg-[var(--color-blue)] px-3 py-2 text-xs font-semibold text-white shadow-sm shadow-[#0b4aa2]/20"
          data-track="click_contact_from_product"
          data-track-label={product.slug}
          data-home-jump={useHomeJump ? "contact" : undefined}
        >
          {t.actions.discussBlade}
        </a>
      </div>
    </div>
  </article>
)}
