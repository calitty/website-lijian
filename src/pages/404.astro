---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  lang="en"
  title="Page Not Found"
  description="The requested page could not be found."
  path="/"
  noindex
>
  <section class="container-page py-24">
    <p class="text-sm font-semibold text-[var(--color-green)]">404</p>
    <h1 data-not-found-title class="mt-3 text-4xl font-semibold text-[var(--color-ink)]">Page Not Found</h1>
    <p data-not-found-body class="mt-4 max-w-xl text-lg leading-8 text-slate-600">
      The page may have moved. Start again from the English homepage or contact us for blade inquiries.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a data-not-found-home href="/en/" class="bg-[var(--color-blue)] px-5 py-3 font-semibold text-white">Home</a>
      <a data-not-found-contact href="/en/contact/" class="border border-[var(--color-border)] px-5 py-3 font-semibold text-[var(--color-ink)]">Contact</a>
    </div>
  </section>
  <script>
    type NotFoundCopy = {
      title: string;
      body: string;
      home: string;
      contact: string;
    };
    const copies: Record<string, NotFoundCopy> = {
      en: {
        title: "Page Not Found",
        body: "The page may have moved. Start again from the homepage or contact us for blade inquiries.",
        home: "Home",
        contact: "Contact",
      },
      ru: {
        title: "Страница не найдена",
        body: "Страница могла быть перемещена. Вернитесь на главную или свяжитесь с нами по вопросу ножей.",
        home: "Главная",
        contact: "Контакты",
      },
      ar: {
        title: "الصفحة غير موجودة",
        body: "ربما تم نقل الصفحة. ابدأ من الصفحة الرئيسية أو تواصل معنا بخصوص الشفرات.",
        home: "الرئيسية",
        contact: "تواصل معنا",
      },
      es: {
        title: "Página no encontrada",
        body: "La página puede haberse movido. Vuelva al inicio o contáctenos para consultas de cuchillas.",
        home: "Inicio",
        contact: "Contacto",
      },
      pt: {
        title: "Página não encontrada",
        body: "A página pode ter sido movida. Volte ao início ou fale conosco sobre lâminas.",
        home: "Início",
        contact: "Contato",
      },
      tr: {
        title: "Sayfa bulunamadı",
        body: "Sayfa taşınmış olabilir. Ana sayfaya dönün veya bıçak talepleri için bizimle iletişime geçin.",
        home: "Ana sayfa",
        contact: "İletişim",
      },
      de: {
        title: "Seite nicht gefunden",
        body: "Die Seite wurde möglicherweise verschoben. Gehen Sie zur Startseite oder kontaktieren Sie uns zu Messeranfragen.",
        home: "Start",
        contact: "Kontakt",
      },
      fr: {
        title: "Page introuvable",
        body: "La page a peut-être été déplacée. Revenez à l'accueil ou contactez-nous pour une demande de lame.",
        home: "Accueil",
        contact: "Contact",
      },
      it: {
        title: "Pagina non trovata",
        body: "La pagina potrebbe essere stata spostata. Torna alla home o contattaci per richieste sulle lame.",
        home: "Home",
        contact: "Contatti",
      },
      th: {
        title: "ไม่พบหน้า",
        body: "หน้านี้อาจถูกย้ายแล้ว กลับไปหน้าแรกหรือติดต่อเราเพื่อสอบถามใบมีด",
        home: "หน้าแรก",
        contact: "ติดต่อเรา",
      },
      vi: {
        title: "Không tìm thấy trang",
        body: "Trang có thể đã được di chuyển. Hãy quay lại trang chủ hoặc liên hệ để hỏi về dao.",
        home: "Trang chủ",
        contact: "Liên hệ",
      },
      id: {
        title: "Halaman tidak ditemukan",
        body: "Halaman mungkin telah dipindahkan. Kembali ke beranda atau hubungi kami untuk kebutuhan pisau.",
        home: "Beranda",
        contact: "Kontak",
      },
      zh: {
        title: "页面未找到",
        body: "页面可能已移动。您可以返回首页，或联系我们沟通食品机械刀片需求。",
        home: "首页",
        contact: "联系我们",
      },
    };

    const supported = new Set(Object.keys(copies));
    const firstSegment = window.location.pathname.split("/").filter(Boolean)[0];
    const browserLang = navigator.language?.slice(0, 2);
    const lang = supported.has(firstSegment) ? firstSegment : supported.has(browserLang) ? browserLang : "en";
    const copy = copies[lang];
    document.documentElement.lang = lang;
    document.documentElement.dir = lang === "ar" ? "rtl" : "ltr";
    const titleEl = document.querySelector<HTMLElement>("[data-not-found-title]");
    const bodyEl = document.querySelector<HTMLElement>("[data-not-found-body]");
    const homeLink = document.querySelector<HTMLAnchorElement>("[data-not-found-home]");
    const contactLink = document.querySelector<HTMLAnchorElement>("[data-not-found-contact]");
    if (titleEl && bodyEl && homeLink && contactLink) {
      titleEl.textContent = copy.title;
      bodyEl.textContent = copy.body;
      homeLink.textContent = copy.home;
      homeLink.href = `/${lang}/`;
      contactLink.textContent = copy.contact;
      contactLink.href = `/${lang}/contact/`;
    }
  </script>
</BaseLayout>
