---
import { defaultLang, langCodes, languages } from "@/data/site";

const site = "https://lijianblades.com";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Maanshan Lijian Food Machine Blades</title>
    <meta
      name="description"
      content="Maanshan Lijian is a Chinese source manufacturer of custom and OEM replacement blades for food processing machinery."
    />
    <meta name="robots" content="noindex, follow" />
    {langCodes.map((code) => <link rel="alternate" hreflang={languages[code].locale} href={`${site}/${code}/`} />)}
    <link rel="alternate" hreflang="x-default" href={`${site}/${defaultLang}/`} />
  </head>
  <body>
    <script is:inline define:vars={{ defaultLang, langCodes }}>
      const supported = new Set(langCodes);
      const getStoredLanguage = () => {
        try {
          const stored = localStorage.getItem("preferred_language");
          return supported.has(stored) ? stored : "";
        } catch {
          return "";
        }
      };
      const getCountry = (locale) => {
        const match = String(locale || "").match(/[-_]([a-z]{2})$/i);
        return match ? match[1].toUpperCase() : "";
      };
      const localeList = Array.from(new Set([navigator.language, ...(navigator.languages || [])].filter(Boolean)));
      const languageCodes = localeList.map((locale) => String(locale).toLowerCase().split(/[-_]/)[0]);
      const countryCodes = localeList.map(getCountry).filter(Boolean);
      const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone || "";
      const hasAny = (items, values) => items.some((item) => values.has(item));

      const zhCountries = new Set(["CN", "HK", "MO", "TW"]);
      const ruCountries = new Set(["RU", "BY", "KZ", "KG"]);
      const arCountries = new Set(["AE", "SA", "QA", "KW", "BH", "OM", "YE", "IQ", "JO", "LB", "SY", "PS", "EG", "MA", "DZ", "TN", "LY", "SD"]);
      const esCountries = new Set(["ES", "MX", "EC", "AR", "CL", "CO", "PE", "VE", "UY", "PY", "BO", "CR", "PA", "GT", "DO", "HN", "SV", "NI", "CU"]);
      const ptCountries = new Set(["BR", "PT", "AO", "MZ"]);
      const trCountries = new Set(["TR"]);
      const deCountries = new Set(["DE", "AT", "CH", "LI"]);
      const frCountries = new Set(["FR", "BE", "CH", "LU", "DZ", "MA", "TN", "CA"]);
      const itCountries = new Set(["IT", "SM", "VA", "CH"]);
      const thCountries = new Set(["TH"]);
      const viCountries = new Set(["VN"]);
      const idCountries = new Set(["ID"]);
      const zhTimeZones = new Set(["Asia/Shanghai", "Asia/Hong_Kong", "Asia/Macau", "Asia/Taipei", "Asia/Urumqi"]);
      const ruTimeZones = new Set([
        "Europe/Moscow",
        "Europe/Kaliningrad",
        "Europe/Samara",
        "Europe/Minsk",
        "Asia/Yekaterinburg",
        "Asia/Omsk",
        "Asia/Novosibirsk",
        "Asia/Barnaul",
        "Asia/Tomsk",
        "Asia/Krasnoyarsk",
        "Asia/Irkutsk",
        "Asia/Yakutsk",
        "Asia/Vladivostok",
        "Asia/Magadan",
        "Asia/Sakhalin",
        "Asia/Kamchatka",
        "Asia/Almaty",
        "Asia/Aqtau",
        "Asia/Aqtobe",
        "Asia/Oral",
        "Asia/Qostanay",
        "Asia/Qyzylorda",
        "Asia/Bishkek",
      ]);
      const arTimeZones = new Set([
        "Asia/Dubai",
        "Asia/Riyadh",
        "Asia/Qatar",
        "Asia/Kuwait",
        "Asia/Bahrain",
        "Asia/Muscat",
        "Asia/Baghdad",
        "Asia/Amman",
        "Asia/Beirut",
        "Asia/Damascus",
        "Asia/Gaza",
        "Asia/Jerusalem",
        "Africa/Cairo",
        "Africa/Casablanca",
        "Africa/Algiers",
        "Africa/Tunis",
      ]);
      const esTimeZones = new Set([
        "Europe/Madrid",
        "America/Mexico_City",
        "America/Guayaquil",
        "America/Argentina/Buenos_Aires",
        "America/Santiago",
        "America/Bogota",
        "America/Lima",
        "America/Caracas",
        "America/Montevideo",
        "America/Asuncion",
        "America/La_Paz",
      ]);
      const ptTimeZones = new Set(["America/Sao_Paulo", "Europe/Lisbon", "Africa/Luanda", "Africa/Maputo"]);
      const trTimeZones = new Set(["Europe/Istanbul"]);
      const deTimeZones = new Set(["Europe/Berlin", "Europe/Vienna", "Europe/Zurich"]);
      const frTimeZones = new Set(["Europe/Paris", "Europe/Brussels", "Europe/Zurich", "Africa/Algiers", "Africa/Casablanca", "Africa/Tunis"]);
      const itTimeZones = new Set(["Europe/Rome", "Europe/Zurich"]);
      const thTimeZones = new Set(["Asia/Bangkok"]);
      const viTimeZones = new Set(["Asia/Ho_Chi_Minh"]);
      const idTimeZones = new Set(["Asia/Jakarta", "Asia/Makassar", "Asia/Jayapura", "Asia/Pontianak"]);

      const detectLanguage = () => {
        if (languageCodes.includes("zh") || hasAny(countryCodes, zhCountries) || zhTimeZones.has(timeZone)) return "zh";
        if (languageCodes.includes("ru") || hasAny(countryCodes, ruCountries) || ruTimeZones.has(timeZone)) return "ru";
        if (languageCodes.includes("ar") || hasAny(countryCodes, arCountries) || arTimeZones.has(timeZone)) return "ar";
        if (languageCodes.includes("es") || hasAny(countryCodes, esCountries) || esTimeZones.has(timeZone)) return "es";
        if (languageCodes.includes("pt") || hasAny(countryCodes, ptCountries) || ptTimeZones.has(timeZone)) return "pt";
        if (languageCodes.includes("tr") || hasAny(countryCodes, trCountries) || trTimeZones.has(timeZone)) return "tr";
        if (languageCodes.includes("de") || hasAny(countryCodes, deCountries) || deTimeZones.has(timeZone)) return "de";
        if (languageCodes.includes("fr") || hasAny(countryCodes, frCountries) || frTimeZones.has(timeZone)) return "fr";
        if (languageCodes.includes("it") || hasAny(countryCodes, itCountries) || itTimeZones.has(timeZone)) return "it";
        if (languageCodes.includes("th") || hasAny(countryCodes, thCountries) || thTimeZones.has(timeZone)) return "th";
        if (languageCodes.includes("vi") || languageCodes.includes("vn") || hasAny(countryCodes, viCountries) || viTimeZones.has(timeZone)) return "vi";
        if (languageCodes.includes("id") || hasAny(countryCodes, idCountries) || idTimeZones.has(timeZone)) return "id";
        return defaultLang;
      };
      const next = getStoredLanguage() || detectLanguage();
      window.location.replace(`/${supported.has(next) ? next : defaultLang}/`);
    </script>
    <main>
      <h1>Industrial Food Blades</h1>
      <p>
        <a href="/en/">English</a>
        <a href="/ru/">Русский</a>
        <a href="/ar/">العربية</a>
        <a href="/es/">Español</a>
        <a href="/pt/">Português</a>
        <a href="/tr/">Türkçe</a>
        <a href="/de/">Deutsch</a>
        <a href="/fr/">Français</a>
        <a href="/it/">Italiano</a>
        <a href="/th/">ไทย</a>
        <a href="/vi/">Tiếng Việt</a>
        <a href="/id/">Bahasa Indonesia</a>
        <a href="/zh/">简体中文</a>
      </p>
    </main>
  </body>
</html>
