    items: ["扫描电镜", "能谱成分", "金相组织", "硬度数据"],
  },
} as const;
const homeQualityReports = homeQualityReportsByLang[lang as keyof typeof homeQualityReportsByLang] ?? homeQualityReportsByLang.en;
const homeQualityReportImages = [
  "/images/quality/report-sem-cropped.jpg",
  "/images/quality/report-eds-cropped.jpg",
  "/images/quality/report-metallography-cropped.jpg",
  "/images/quality/report-hardness-cropped.jpg",
];
const homeManufacturingCapabilitiesByLang = {
  en: [
    ["Drawing To Production", "Convert drawings, old samples or machine models into controlled profile, hole and thickness requirements."],
    ["CNC Hole And Slot Control", "Focus on mounting holes, slots, bore size and replacement fit for easier installation."],
    ["Heat Treatment And Hardness", "Match hardness target with cutting load, impact risk and edge retention requirement."],
    ["Precision Grinding", "Control thickness, flatness, straightness and bevel consistency before final edge finishing."],
