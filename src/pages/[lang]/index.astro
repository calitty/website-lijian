---

<BaseLayout
  lang={lang}
  title={t.seo.homeTitle}
  description={t.seo.homeDescription}
  path={path}
  image={ogImage}
  preloadImage={heroBannerWebp}
  jsonLd={homeJsonLd}
>
  <section class="relative isolate overflow-hidden border-b border-[#dbe6f5] bg-[#edf4fb] text-[var(--color-ink)]" aria-label={heroCarouselCopy.aria} data-hero-root>
    <div class="absolute inset-0" data-hero-carousel data-interval="6200">
      {heroSlides.map((slide, index) => (
        <div
          class:list={[
            "absolute inset-0 transition-opacity duration-700 ease-out motion-reduce:transition-none",
            index === 0 ? "opacity-100" : "opacity-0",
          ]}
          data-hero-slide
          data-hero-index={index}
          data-hero-title={slide.title}
          data-hero-eyebrow-copy={slide.eyebrowText}
          data-hero-headline-main-copy={slide.headlineMainText}
          data-hero-headline-accent-copy={slide.headlineAccentText}
          data-hero-caption-copy={slide.introText}
          aria-hidden={index === 0 ? "false" : "true"}
        >
          <Img
            src={slide.image}
            alt={slide.title}
            class={`h-full w-full object-cover ${slide.imageClass}`}
            loading={index === 0 ? "eager" : "lazy"}
            fetchpriority={index === 0 ? "high" : "auto"}
          />
        </div>
      ))}
    </div>
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(248,251,255,.98)_0%,rgba(242,247,253,.94)_36%,rgba(242,247,253,.48)_61%,rgba(242,247,253,.08)_100%)] rtl:bg-[linear-gradient(270deg,rgba(248,251,255,.98)_0%,rgba(242,247,253,.94)_36%,rgba(242,247,253,.48)_61%,rgba(242,247,253,.08)_100%)]"></div>
    <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-white/76 to-transparent"></div>

    <div class="container-page relative flex min-h-[480px] items-start py-7 pb-8 max-[360px]:min-h-[390px] max-[360px]:py-4 max-[360px]:pb-5 sm:min-h-[500px] sm:items-center sm:py-10 md:min-h-[540px] md:py-14">
      <div class="min-w-0 max-w-2xl">
        <p class="max-w-full break-words text-xs font-semibold uppercase text-[var(--color-blue)] [overflow-wrap:anywhere]" data-hero-eyebrow>{heroSlides[0].eyebrowText}</p>
        <h1 class="mt-4 min-h-[9.5rem] max-w-full break-words text-[1.8rem] font-semibold leading-tight tracking-normal text-[var(--color-ink)] [overflow-wrap:anywhere] max-[360px]:mt-2 max-[360px]:text-[1.46rem] max-[360px]:leading-[1.14] sm:mt-5 sm:min-h-[7rem] sm:text-[2.55rem] md:min-h-[8rem] md:text-[3rem]">
          <span class="block" data-hero-headline-main>
            {heroSlides[0].headlineLines.map((line) => <span class="block max-w-full break-words [overflow-wrap:anywhere] md:inline md:after:content-['\\00a0']">{line}</span>)}
          </span>
          <span class="mt-2 block text-[var(--color-blue)]" data-hero-headline-accent>
            {heroSlides[0].accentLines.map((line) => <span class="block max-w-full break-words [overflow-wrap:anywhere] md:inline md:after:content-['\\00a0']">{line}</span>)}
          </span>
        </h1>
        <p class="mt-4 max-w-xl break-words text-sm leading-7 text-slate-600 [overflow-wrap:anywhere] max-[360px]:mt-2 max-[360px]:text-[12.5px] max-[360px]:leading-5 sm:text-base md:text-lg" data-hero-caption>{heroSlides[0].introText}</p>

        <div class="mt-5 grid grid-cols-2 gap-2.5 max-[360px]:mt-3 max-[360px]:gap-1.5 sm:mt-7 sm:grid-cols-2 sm:gap-3 lg:grid-cols-4">
          {t.home.trust.map((item) => (
            <span class="grid min-h-13 grid-cols-[28px_1fr] items-center gap-2 rounded-[6px] border border-[#d7e5f7] bg-white/78 px-2.5 py-2 text-[11px] font-semibold leading-4 text-slate-700 shadow-[0_8px_22px_rgba(9,42,94,.06)] backdrop-blur [overflow-wrap:anywhere] max-[360px]:min-h-10 max-[360px]:grid-cols-[22px_1fr] max-[360px]:gap-1.5 max-[360px]:px-1.5 max-[360px]:py-1 max-[360px]:text-[10px] sm:min-h-16 sm:grid-cols-[34px_1fr] sm:gap-3 sm:px-3 sm:py-3 sm:text-xs sm:leading-5">
              <span class="grid h-7 w-7 place-items-center rounded-full border border-[#c8daf1] bg-[var(--color-blue-soft)] max-[360px]:h-[22px] max-[360px]:w-[22px] sm:h-8 sm:w-8" aria-hidden="true">
                <span class="h-3 w-3 rounded-[4px] border-2 border-[var(--color-blue)] max-[360px]:h-2 max-[360px]:w-2 sm:h-3.5 sm:w-3.5"></span>
              </span>
              <span class="min-w-0 break-words">{item}</span>
            </span>
          ))}
