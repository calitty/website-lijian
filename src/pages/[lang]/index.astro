    title: "Dải dao chính",
    lead: "Với dao thay thế và OEM, hãy bắt đầu từ loại dao gần nhất. Sau khi nhận bản vẽ, mẫu cũ hoặc model máy, chúng tôi xác nhận biên dạng, lỗ, độ dày, vật liệu và cạnh dao.",
    cta: "Mở sản phẩm",
  },
  id: {
    title: "Rentang Pisau Utama",
    lead: "Untuk pisau pengganti dan OEM, mulai dari jenis pisau terdekat. Setelah menerima gambar, sampel lama atau model mesin, kami mengonfirmasi profil, lubang, ketebalan, material dan geometri mata pisau.",
    cta: "Buka Produk",
  },
  zh: {
    title: "核心产品范围",
    lead: "面向替换刀片和 OEM 设备配套采购，可先按刀片形状或设备用途确认方向。客户提供图纸、旧刀样品或设备型号后，我们再确认外形、孔位、厚度、材料与刃口结构。",
    cta: "进入完整产品中心",
  },
} as const;
const productSummary = productSummaryByLang[lang as keyof typeof productSummaryByLang] ?? {
  ...productSummaryByLang.en,
  title: t.nav.products,
  lead: t.home.productsLead,
  cta: t.actions.viewProducts,
};
const homeQualityReportsByLang = {
  en: {
    title: "Inspection Report Samples",
    items: ["SEM edge", "EDS spectrum", "Metallography", "Hardness"],
  },
  ru: {
    title: "Примеры Отчетов Контроля",
    items: ["SEM кромки", "EDS спектр", "Металлография", "Твердость"],
  },
  ar: {
    title: "عينات تقارير الفحص",
    items: ["SEM للحافة", "تحليل EDS", "الفحص المعدني", "الصلابة"],
  },
  th: {
    title: "ตัวอย่างรายงานตรวจสอบ",
    items: ["SEM คม", "สเปกตรัม EDS", "โครงสร้างโลหะ", "ความแข็ง"],
  },
  vi: {
