    ["CNC Отверстия И Пазы", "Контроль отверстий, пазов, посадочного диаметра и монтажа сменного ножа."],
    ["Термообработка И Твердость", "Подбор твердости под нагрузку резки, ударный риск и ресурс кромки."],
    ["Точное Шлифование", "Контроль толщины, плоскостности, прямолинейности и фаски перед финишем."],
    ["Геометрия Кромки", "Одинарная, двойная фаска, зуб или шаг под материал резки."],
    ["Повторные Заказы", "Сохранение ключевых размеров и производственных данных для следующих партий."],
  ],
  ar: [
    ["من الرسم إلى الإنتاج", "تحويل الرسومات أو العينات أو موديلات الأجهزة إلى أبعاد يمكن التحكم بها."],
    ["تحكم فتحات CNC", "التركيز على الفتحات، الشقوق، القطر الداخلي وملاءمة التركيب."],
    ["المعالجة الحرارية", "مطابقة الصلابة مع حمل القطع وخطر الصدمات وعمر الحافة."],
    ["جلخ دقيق", "التحكم في السماكة، الاستواء، الاستقامة وثبات الشطف."],
    ["هندسة الحافة", "تعديل الحافة الواحدة أو المزدوجة أو الأسنان حسب مادة القطع."],
    ["سجلات الطلبات المتكررة", "حفظ الأبعاد الرئيسية وتفاصيل الإنتاج للدفعات اللاحقة."],
  ],
  th: [
    ["จากแบบสู่การผลิต", "แปลงแบบ ตัวอย่างเก่า หรือรุ่นเครื่องเป็นข้อกำหนดรูปทรง รู และความหนา"],
    ["ควบคุมรูและร่อง CNC", "เน้นรูติดตั้ง ร่อง รูใน และความพอดีสำหรับการเปลี่ยนใบมีด"],
    ["ชุบแข็งและความแข็ง", "จับคู่ความแข็งกับแรงตัด ความเสี่ยงกระแทก และอายุคม"],
    ["เจียรละเอียด", "ควบคุมความหนา ความเรียบ ความตรง และความสม่ำเสมอก่อนแต่งคม"],
    ["รูปทรงคม", "ปรับคมเดี่ยว คมคู่ ฟัน หรือระยะฟันตามวัสดุที่ตัด"],
    ["บันทึกการสั่งซ้ำ", "เก็บขนาดหลักและรายละเอียดผลิตสำหรับล็อตทดแทนครั้งต่อไป"],
  ],
  vi: [
    ["Từ bản vẽ đến sản xuất", "Chuyển bản vẽ, mẫu cũ hoặc model máy thành yêu cầu biên dạng, lỗ và độ dày."],
    ["Kiểm soát lỗ và rãnh CNC", "Tập trung vào lỗ lắp, rãnh, đường kính trong và độ vừa lắp khi thay thế."],
    ["Nhiệt luyện và độ cứng", "Khớp độ cứng với tải cắt, rủi ro va đập và yêu cầu giữ cạnh."],
    ["Mài chính xác", "Kiểm soát độ dày, độ phẳng, độ thẳng và độ ổn định trước khi hoàn thiện cạnh."],
    ["Hình học cạnh", "Điều chỉnh cạnh đơn, cạnh kép, răng hoặc bước răng theo vật liệu cắt."],
    ["Hồ sơ đơn hàng lặp", "Lưu kích thước chính và dữ liệu sản xuất cho các lô thay thế sau."],
  ],
  id: [
    ["Dari gambar ke produksi", "Mengubah gambar, sampel lama atau model mesin menjadi persyaratan profil, lubang dan ketebalan yang terkontrol."],
    ["Kontrol lubang dan slot CNC", "Fokus pada lubang pemasangan, slot, diameter bore dan kecocokan penggantian untuk pemasangan lebih mudah."],
    ["Heat treatment dan kekerasan", "Mencocokkan target kekerasan dengan beban potong, risiko benturan dan kebutuhan ketahanan mata pisau."],
    ["Grinding presisi", "Mengontrol ketebalan, kerataan, kelurusan dan konsistensi bevel sebelum finishing akhir."],
    ["Geometri mata pisau", "Menyesuaikan single bevel, double bevel, serration atau pitch gigi sesuai bahan yang dipotong."],
    ["Catatan repeat order", "Menyimpan ukuran utama dan detail produksi untuk batch pengganti berikutnya."],
  ],
  zh: [
    ["图纸转化生产", "把图纸、旧刀样品或设备型号转化为外形、孔位、厚度和刃口要求。"],
    ["CNC 孔槽控制", "重点控制安装孔、槽位、内孔和关键装机尺寸，减少替换刀片现场调机。"],
    ["热处理与硬度", "按切割负载、抗冲击和刃口保持要求确认硬度范围。"],
    ["精密磨削", "控制厚度、平面度、直线度和刃口前的磨削一致性。"],
    ["刃口几何", "按食品材料确认单面刃、双面刃、齿形、齿距或打孔间距。"],
    ["复购批次记录", "沉淀关键尺寸和生产记录，便于后续替换刀片复购。"],
  ],
} as const;
const homeManufacturingCapabilities =
  homeManufacturingCapabilitiesByLang[lang as keyof typeof homeManufacturingCapabilitiesByLang] ?? homeManufacturingCapabilitiesByLang.en;
const aboutHighlights = homeFactory.stats.slice(0, 4);
---

<BaseLayout
  lang={lang}
  title={t.seo.homeTitle}
  description={t.seo.homeDescription}
  path={path}
  image={productImages.hero}
  jsonLd={[pageJsonLd]}
>
  <section
    class="relative overflow-hidden bg-[var(--color-ink)] text-white"
    style={`background-image: linear-gradient(90deg, rgba(15,18,24,.98), rgba(15,18,24,.86) 44%, rgba(15,18,24,.34)), url('${productImages.hero}'); background-size: cover; background-position: center;`}
  >
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,.08),rgba(0,0,0,.42))]"></div>
    <div class="container-page relative grid min-h-[72vh] gap-10 py-16 lg:grid-cols-[1fr_.78fr] lg:items-center">
      <div class="min-w-0 max-w-4xl">
        <p class="max-w-full break-words text-sm font-semibold uppercase text-[var(--color-silver)]">{t.home.eyebrow}</p>
        <p class="mt-4 inline-block max-w-full break-words rounded-[4px] border border-white/15 bg-white/10 px-3 py-2 text-xs font-semibold text-slate-100">{polish.heroKicker}</p>
        <h1 class="mt-5 max-w-full break-words text-[2.35rem] font-semibold uppercase leading-[1.04] md:text-6xl">
          <span class="block">
            {heroMainLines.map((line) => <span class="block">{line}</span>)}
          </span>
          <span class="mt-2 block text-[var(--color-red)]">
            {heroAccentLines.map((line) => <span class="block">{line}</span>)}
          </span>
        </h1>
        <p class="mt-6 max-w-2xl break-words text-lg leading-8 text-slate-200 md:text-xl">{t.home.intro}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#products" class="rounded-[4px] bg-[var(--color-red)] px-5 py-3 font-semibold text-white" data-home-jump="products">
            {t.actions.viewProducts}
          </a>
          <a href="#contact" class="rounded-[4px] border border-white/40 px-5 py-3 font-semibold text-white" data-home-jump="contact">
            {t.actions.contactUs}
          </a>
        </div>
      </div>

      <img src={productImages.circular} alt={t.nav.products} class="hidden aspect-square w-full rounded-[6px] border border-white/12 bg-black/20 object-contain p-10 lg:block" loading="lazy" />
    </div>
    <div class="relative border-t border-white/10 bg-black/24">
      <div class="container-page grid gap-2 py-5 sm:grid-cols-2 lg:grid-cols-4">
        {t.home.trust.map((item) => (
          <span class="rounded-[4px] border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-slate-100">{item}</span>
        ))}
      </div>
    </div>
  </section>

  <section id="products" data-home-section="products" class="scroll-mt-24 border-b border-slate-200 bg-white py-12 md:py-14">
    <div class="container-page">
      <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <SectionHeading title={t.nav.products} lead={productSummary.lead} />
        {/*
        <a href={withLang(lang, "/products")} class="mt-6 inline-flex rounded-[4px] bg-[var(--color-ink)] px-4 py-3 text-sm font-semibold text-white">
          {productSummary.cta}
        </a>
        */}
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featuredProducts.map((product) => (
          <ProductCard product={product} lang={lang} contactHref="#contact" useHomeJump />
        ))}
      </div>
    </div>
  </section>

  <section id="applications" data-home-section="applications" class="scroll-mt-24 bg-[var(--color-mist)] py-16 md:py-20">
    <div class="container-page">
      <SectionHeading title={t.nav.applications} lead={t.home.applicationsLead} />
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {featuredApplications.map((application) => (
          <article class="overflow-hidden rounded-[6px] border border-slate-200 bg-white shadow-sm">
            <div class="relative overflow-hidden">
              <img src={application.image} alt={localize(application.name, lang)} class="aspect-[4/3] w-full object-cover" loading="lazy" />
            </div>
            <div class="p-5">
              <h3 class="text-xl font-semibold text-[var(--color-ink)]">{localize(application.name, lang)}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">{localize(application.summary, lang)}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {localizeList(application.focus, lang).slice(0, 3).map((item) => (
                  <span class="rounded-[4px] bg-[var(--color-mist)] px-2.5 py-1 text-xs font-semibold text-slate-600">{item}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="manufacturing" data-home-section="manufacturing" class="scroll-mt-24 bg-white py-16 md:py-20">
    <div class="container-page grid gap-10 lg:grid-cols-[1fr_1fr] lg:items-center">
      <div>
        <SectionHeading title={t.nav.manufacturing} lead={t.home.manufacturingLead} />
        <div class="mt-8 grid gap-3">
          {homeManufacturingCapabilities.map(([title, text], index) => (
            <article class="grid gap-3 border border-[var(--color-border)] bg-white p-4 sm:grid-cols-[44px_1fr]">
              <span class="grid h-10 w-10 shrink-0 place-items-center bg-[var(--color-blue)] text-sm font-semibold text-white">{String(index + 1).padStart(2, "0")}</span>
              <span>
                <h3 class="text-base font-semibold text-[var(--color-ink)]">{title}</h3>
                <p class="mt-1 text-sm leading-6 text-slate-600">{text}</p>
              </span>
            </article>
          ))}
        </div>
      </div>
      <img src={productImages.manufacturing} alt={t.nav.manufacturing} class="aspect-[4/3] w-full rounded-[6px] object-cover" loading="lazy" />
    </div>
  </section>

  <section id="quality" data-home-section="quality" class="scroll-mt-24 bg-[var(--color-mist)] py-16 md:py-20">
    <div class="container-page">
      <SectionHeading title={t.nav.quality} lead={t.home.qualityLead} />
      <div class="mt-10 grid gap-6 lg:grid-cols-[.92fr_1.08fr] lg:items-start">
        <article class="overflow-hidden rounded-[6px] border border-slate-200 bg-white shadow-sm">
          <img src={productImages.quality} alt={t.nav.quality} class="aspect-[4/3] w-full object-cover" loading="lazy" />
          <div class="border-t border-slate-200 p-5">
            <p class="text-sm leading-7 text-slate-600">{t.seo.qualityDescription}</p>
          </div>
        </article>

        <div class="grid gap-5">
          <div class="grid gap-3 sm:grid-cols-2">
            {qualityChecks[lang].slice(0, 6).map((check) => (
              <span class="rounded-[4px] border border-slate-200 bg-white px-4 py-3 text-sm font-semibold leading-6 text-[var(--color-ink)] shadow-sm">{check}</span>
            ))}
          </div>
          <div class="rounded-[6px] border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between gap-4 border-b border-slate-200 pb-4">
              <h3 class="text-base font-semibold text-[var(--color-ink)]">{homeQualityReports.title}</h3>
              <span class="hidden rounded-[4px] bg-[var(--color-ink)] px-3 py-1.5 text-xs font-semibold text-white sm:inline-flex">{t.labels.inspection}</span>
            </div>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
              {homeQualityReportImages.map((image, index) => (
                <figure class="rounded-[4px] border border-slate-200 bg-[var(--color-mist)] p-2">
                  <img src={image} alt={homeQualityReports.items[index]} class="aspect-[16/9] w-full object-contain" loading="lazy" />
                  <figcaption class="mt-2 text-xs font-semibold text-slate-600">{homeQualityReports.items[index]}</figcaption>
                </figure>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="about" data-home-section="about" class="scroll-mt-24 bg-white py-16 md:py-20">
    <div class="container-page grid gap-10 lg:grid-cols-[.95fr_1.05fr] lg:items-center">
      <div>
        <SectionHeading title={t.nav.about} lead={homeFactory.lead} />
        <div class="mt-6 grid gap-px overflow-hidden rounded-[6px] border border-slate-200 bg-slate-200 sm:grid-cols-2">
          {aboutHighlights.map(([value, label]) => (
            <div class="bg-[var(--color-mist)] p-4">
              <p class="text-2xl font-semibold text-[var(--color-ink)]">{value}</p>
              <p class="mt-1 text-sm font-semibold text-slate-600">{label}</p>
            </div>
          ))}
        </div>
      </div>
      <img src={productImages.factoryGate} alt={t.nav.about} class="aspect-[16/10] w-full rounded-[6px] object-cover shadow-sm" loading="lazy" />
    </div>
  </section>

  <section id="contact" data-home-section="contact" class="scroll-mt-24 border-t border-slate-200 bg-[var(--color-mist)] py-14 md:py-16">
    <div class="container-page">
      <div class="grid gap-5 lg:grid-cols-[.72fr_1.28fr] lg:items-end">
        <SectionHeading title={homeFactory.contactTitle} lead={homeFactory.contactLead} />
        <p class="rounded-[6px] border border-slate-200 bg-white p-4 text-sm leading-7 text-slate-600 shadow-sm">{homeFactory.contactDetail}</p>
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-[1.05fr_.95fr] lg:items-start">
        <InquiryForm lang={lang} tone="light" />

        <aside class="rounded-[6px] border border-slate-200 bg-white p-5 shadow-sm">
          <div class="grid gap-4 sm:grid-cols-[120px_1fr] sm:items-center">
            <div class="rounded-[6px] border border-slate-200 bg-[var(--color-mist)] p-2">
              <img src={contact.whatsappQr} alt={t.labels.whatsappQr} class="aspect-square w-full rounded-[4px] object-contain" loading="lazy" />
            </div>
            <div>
              <h3 class="text-2xl font-semibold leading-snug text-[var(--color-ink)]">{contactPanel.whatsapp}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-600">{contactPanel.directLead}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                <a href={channelLinks.whatsapp} class="rounded-[4px] bg-[#25d366] px-4 py-2.5 text-sm font-semibold text-[#06130b]" data-track="click_whatsapp">
                  {t.labels.openWhatsapp}
                </a>
                <a href={channelLinks.email} class="rounded-[4px] border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-[var(--color-ink)]" data-track="click_email">
                  {contactPanel.email}
                </a>
              </div>
            </div>
          </div>

          <div class="mt-5 grid gap-3 border-t border-slate-200 pt-5 sm:grid-cols-2">
            <a href={channelLinks.whatsapp} class="rounded-[4px] border border-slate-200 bg-[var(--color-mist)] p-4" data-track="click_whatsapp">
              <span class="block text-xs font-semibold uppercase text-slate-500">WhatsApp</span>
              <span class="mt-2 block text-base font-semibold text-[var(--color-ink)]">{contact.whatsapp}</span>
            </a>
            <a href={channelLinks.email} class="rounded-[4px] border border-slate-200 bg-[var(--color-mist)] p-4" data-track="click_email">
              <span class="block text-xs font-semibold uppercase text-slate-500">Email</span>
              <span class="mt-2 block break-all text-base font-semibold text-[var(--color-ink)]">{contact.email}</span>
            </a>
          </div>

          <div class="mt-5 border-t border-slate-200 pt-5">
            <h3 class="text-sm font-semibold text-[var(--color-ink)]">{contactPanel.departments}</h3>
            <div class="mt-3 grid gap-3">
              {contact.departments.map((department) => (
                <a
                  href={`tel:${department.phone.replace(/\s/g, "")}`}
                  class="grid gap-3 rounded-[4px] border border-slate-200 bg-[var(--color-mist)] p-4 sm:grid-cols-[1fr_auto]"
                  data-track="click_phone"
                  data-track-label={department.id}
                >
                  <span>
                    <span class="block text-sm font-semibold text-[var(--color-ink)]">{department.name[lang]}</span>
                    <span class="mt-1 block text-xs leading-5 text-slate-600">
                      <span class="font-semibold text-slate-800">{contactLabels.address}: </span>{department.address[lang]}
                    </span>
                  </span>
                  <span class="text-sm font-semibold text-[var(--color-blue)]">{department.phone}</span>
                </a>
              ))}
            </div>
          </div>

          <div class="mt-5 border-t border-slate-200 pt-5">
            <h3 class="text-sm font-semibold text-[var(--color-ink)]">{contactPanel.prepare}</h3>
            <div class="mt-3 flex flex-wrap gap-2">
              {contactTips.map((item) => (
                <span class="rounded-[4px] border border-slate-200 bg-white px-2.5 py-1 text-xs font-semibold text-slate-600">{item}</span>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
