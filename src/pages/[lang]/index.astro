  <script is:inline>
    (() => {
      const root = document.querySelector("[data-hero-carousel]");
      if (!root) return;

      const section = root.closest("[data-hero-root]");
      if (!section) return;

      const slides = Array.from(root.querySelectorAll("[data-hero-slide]"));
      const dots = Array.from(section.querySelectorAll("[data-hero-dot]"));
      const eyebrow = section.querySelector("[data-hero-eyebrow]");
      const headlineMain = section.querySelector("[data-hero-headline-main]");
      const headlineAccent = section.querySelector("[data-hero-headline-accent]");
      const caption = section.querySelector("[data-hero-caption]");
      const status = section.querySelector("[data-hero-status]");
      const reduceMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
      const interval = Number(root.getAttribute("data-interval")) || 6200;
      let current = 0;
      let timer = 0;

      if (slides.length < 2 || dots.length !== slides.length) return;

      const slideCopy = slides.map((slide) => ({
        title: slide.getAttribute("data-hero-title") || "",
        eyebrow: slide.getAttribute("data-hero-eyebrow-copy") || "",
        headlineMain: slide.getAttribute("data-hero-headline-main-copy") || "",
        headlineAccent: slide.getAttribute("data-hero-headline-accent-copy") || "",
        caption: slide.getAttribute("data-hero-caption-copy") || "",
      }));

      const setDotState = (dot, active) => {
        dot.classList.toggle("w-9", active);
        dot.classList.toggle("w-7", !active);
        dot.classList.toggle("bg-[var(--color-blue)]", active);
        dot.classList.toggle("bg-[#c7d5e8]", !active);
        dot.setAttribute("aria-current", active ? "true" : "false");
      };

      const stop = () => {
        if (!timer) return;
        window.clearInterval(timer);
        timer = 0;
      };

      const start = () => {
        if (timer || reduceMotionQuery.matches) return;
        timer = window.setInterval(() => show(current + 1), interval);
      };

      const show = (nextIndex) => {
        const next = (nextIndex + slides.length) % slides.length;
        if (next === current) return;

        slides.forEach((slide, index) => {
          const active = index === next;
          slide.classList.toggle("opacity-100", active);
          slide.classList.toggle("opacity-0", !active);
          slide.setAttribute("aria-hidden", active ? "false" : "true");
        });
        dots.forEach((dot, index) => setDotState(dot, index === next));

        const copy = slideCopy[next];
        if (eyebrow && copy.eyebrow) eyebrow.textContent = copy.eyebrow;
        if (headlineMain && copy.headlineMain) headlineMain.textContent = copy.headlineMain;
        if (headlineAccent) {
          headlineAccent.textContent = copy.headlineAccent;
          headlineAccent.classList.toggle("hidden", !copy.headlineAccent);
        }
        if (caption && copy.caption) caption.textContent = copy.caption;
        if (status && copy.title) status.textContent = copy.title;

        current = next;
      };

      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => {
          stop();
          show(index);
          start();
        });
      });

      section.addEventListener("pointerenter", stop);
      section.addEventListener("pointerleave", start);
      section.addEventListener("focusin", stop);
      section.addEventListener("focusout", start);
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          stop();
          return;
        }
        start();
      });

      reduceMotionQuery.addEventListener("change", () => {
        stop();
        start();
      });

      start();
    })();
  </script>
