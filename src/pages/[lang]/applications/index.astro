---
import Img from "@/components/Img.astro";
import PageHero from "@/components/PageHero.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildApplicationsItemListJsonLd } from "@/data/geo";
import { applications, buildBreadcrumb, langCodes, localize, localizeList, productImages, ui, withLang, type Lang } from "@/data/site";

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = ui[lang];
const path = "/applications";
const site = Astro.site ?? new URL("https://lijianblades.com");
const breadcrumb = buildBreadcrumb(lang, site, [
  { name: t.nav.home, path: "/" },
  { name: t.nav.applications, path },
]);
