---
import PageHero from "@/components/PageHero.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { applications, buildBreadcrumb, langCodes, localize, localizeList, productImages, ui, type Lang } from "@/data/site";

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = ui[lang];
const path = "/applications";
const site = Astro.site ?? new URL("https://lijianblades.com");
const breadcrumb = buildBreadcrumb(lang, site, [
  { name: t.nav.home, path: "/" },
  { name: t.nav.applications, path },
]);
const solutionCopyByLang = {
  en: {
    problem: "Production Focus",
    items: {
      "meat-processing": "Clean cutting, edge life and fast replacement for meat slicing, trimming and portioning.",
      "poultry-processing": "Compact blade profiles for deboning, dividing and trimming stations with less tearing.",
      "fish-seafood-processing": "Corrosion-aware stainless blades for wet, salty and washdown seafood environments.",
      "frozen-food-processing": "Tougher blade choices for low-temperature cutting, chipping control and packaging.",
      "vegetable-fruit-processing": "Sharp, clean edges for slice consistency, low bruising and easy cleaning.",
      "bakery-snack-processing": "Tooth pitch and edge geometry tuned for bread, pastry, snacks and crumb control.",
      "food-packaging": "Cut-off, perforation and film cutting blades for burr control and line stability.",
    },
  },
  ru: {
    problem: "Фокус Линии",
    items: {
      "meat-processing": "Чистый рез, ресурс кромки и быстрая замена для мясных линий.",
      "poultry-processing": "Компактные профили для обвалки, разделки и жиловки с меньшим разрывом.",
      "fish-seafood-processing": "Нержавеющие ножи для влажной, соленой и моечной среды.",
      "frozen-food-processing": "Прочные ножи для низкой температуры, контроля сколов и упаковки.",
      "vegetable-fruit-processing": "Острые кромки для стабильной нарезки, меньшего смятия и мойки.",
      "bakery-snack-processing": "Шаг зуба и геометрия кромки для хлеба, выпечки, снеков и крошки.",
      "food-packaging": "Отрезка, перфорация и пленка для контроля заусенцев и стабильности линии.",
    },
  },
  ar: {
    problem: "تركيز خط الإنتاج",
    items: {
      "meat-processing": "قطع نظيف وعمر حافة واستبدال سريع لخطوط اللحوم.",
      "poultry-processing": "أشكال مدمجة للتقطيع ونزع العظم والتشذيب مع تمزق أقل.",
      "fish-seafood-processing": "شفرات مقاومة للتآكل للبيئات الرطبة والمالحة.",
      "frozen-food-processing": "شفرات أقوى للقطع منخفض الحرارة وتقليل التكسير.",
      "vegetable-fruit-processing": "حواف حادة لثبات الشرائح وتقليل الكدمات وسهولة التنظيف.",
      "bakery-snack-processing": "سنون وحواف مناسبة للخبز والمعجنات والوجبات الخفيفة.",
      "food-packaging": "شفرات قطع وثقب وأفلام لتقليل النتوءات وثبات الخط.",
    },
  },
  th: {
    problem: "จุดสำคัญของไลน์ผลิต",
    items: {
      "meat-processing": "การตัดสะอาด อายุคม และเปลี่ยนใบมีดได้รวดเร็วสำหรับไลน์เนื้อสัตว์",
      "poultry-processing": "รูปทรงกะทัดรัดสำหรับแยกกระดูก แบ่งชิ้น และตัดแต่ง ลดการฉีก",
      "fish-seafood-processing": "ใบมีดสแตนเลสสำหรับสภาพแวดล้อมเปียก เค็ม และล้างบ่อย",
      "frozen-food-processing": "ใบมีดทนแรงกระแทกสำหรับอุณหภูมิต่ำและลดการบิ่น",
      "vegetable-fruit-processing": "คมตัดสะอาดสำหรับความสม่ำเสมอ ลดช้ำ และทำความสะอาดง่าย",
      "bakery-snack-processing": "ปรับระยะฟันและคมสำหรับขนมปัง เบเกอรี่ และขนมขบเคี้ยว",
      "food-packaging": "ใบมีดตัด เจาะรู และตัดฟิล์มเพื่อลดครีบและเพิ่มเสถียรภาพไลน์",
    },
  },
  vi: {
    problem: "Trọng tâm dây chuyền",
    items: {
      "meat-processing": "Cắt sạch, bền cạnh và thay dao nhanh cho dây chuyền thịt.",
      "poultry-processing": "Biên dạng nhỏ gọn cho rút xương, chia cắt và trimming, giảm xé rách.",
      "fish-seafood-processing": "Dao inox chống ăn mòn cho môi trường ướt, mặn và rửa nhiều.",
      "frozen-food-processing": "Dao bền hơn cho cắt lạnh, kiểm soát mẻ cạnh và đóng gói.",
      "vegetable-fruit-processing": "Cạnh sắc cho lát cắt ổn định, ít dập và dễ vệ sinh.",
      "bakery-snack-processing": "Bước răng và cạnh dao phù hợp bánh mì, bánh ngọt và snack.",
      "food-packaging": "Dao cắt, đục lỗ và cắt màng để kiểm soát ba via và ổn định dây chuyền.",
    },
  },
  id: {
    problem: "Fokus Lini Produksi",
    items: {
      "meat-processing": "Potongan bersih, umur mata pisau dan penggantian cepat untuk lini daging.",
      "poultry-processing": "Profil pisau ringkas untuk deboning, pemotongan dan trimming dengan sobekan lebih rendah.",
      "fish-seafood-processing": "Pisau stainless yang memperhatikan korosi untuk lingkungan basah, asin dan sering dicuci.",
      "frozen-food-processing": "Pilihan pisau lebih kuat untuk pemotongan suhu rendah, kontrol chipping dan kemasan.",
      "vegetable-fruit-processing": "Mata pisau tajam untuk irisan konsisten, mengurangi memar dan mudah dibersihkan.",
      "bakery-snack-processing": "Pitch gigi dan geometri mata pisau disesuaikan untuk roti, pastry, snack dan kontrol remah.",
      "food-packaging": "Pisau cut-off, perforasi dan film cutting untuk kontrol burr dan stabilitas lini.",
    },
  },
  zh: {
    problem: "产线重点",
    items: {
      "meat-processing": "解决肉类切片、修整、分份中的切面、寿命和快速换刀问题。",
      "poultry-processing": "适合禽类剔骨、分割和修整工位，重点减少撕裂并稳定装机。",
      "fish-seafood-processing": "面向潮湿、盐分和频繁清洗环境，重点控制耐腐蚀和表面光洁。",
      "frozen-food-processing": "针对低温切割、冲击负载和崩口风险，兼顾厚度和刃口强度。",
      "vegetable-fruit-processing": "服务果蔬切片、切丁和去皮，重点保持切面整洁和减少压伤。",
      "bakery-snack-processing": "按面包、糕点和零食组织调整齿距、齿形和起切效果。",
      "food-packaging": "用于薄膜切断、打孔、封切和易撕线，重点控制毛刺和高速稳定。",
    },
  },
} as const;
const solutionCopy = solutionCopyByLang[lang as keyof typeof solutionCopyByLang] ?? solutionCopyByLang.en;
---

<BaseLayout
  lang={lang}
  title={t.seo.applicationsTitle}
  description={t.seo.applicationsDescription}
  path={path}
  image={productImages.manufacturing}
  pageEvent="view_application_page"
  pageEventLabel="all-applications"
  jsonLd={[breadcrumb]}
>
  <PageHero eyebrow={t.labels.applicationRange} title={t.seo.applicationsTitle} lead={t.seo.applicationsDescription} image={productImages.environment} imageAlt={t.nav.applications} />

  <section class="bg-white py-16 md:py-20">
    <div class="container-page">
      <SectionHeading title={t.nav.applications} lead={t.home.applicationsLead} />
      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        {applications.map((application) => (
          <article class="grid overflow-hidden rounded-[6px] border border-slate-200 bg-white shadow-sm md:grid-cols-[.92fr_1.08fr]">
            <div class="relative min-h-[260px] overflow-hidden bg-slate-100">
              <img src={application.image} alt={localize(application.name, lang)} class="h-full min-h-[260px] w-full object-cover" loading="lazy" />
            </div>
            <div class="flex flex-col p-6">
              <p class="text-xs font-semibold uppercase text-[var(--color-green)]">{solutionCopy.problem}</p>
              <h2 class="mt-3 text-2xl font-semibold text-[var(--color-ink)]">{localize(application.name, lang)}</h2>
              <p class="mt-4 text-sm leading-7 text-slate-600">{solutionCopy.items[application.slug as keyof typeof solutionCopy.items]}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {localizeList(application.focus, lang).map((item) => (
                  <span class="rounded-[4px] bg-[var(--color-mist)] px-2.5 py-1 text-xs font-semibold text-slate-600">{item}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
