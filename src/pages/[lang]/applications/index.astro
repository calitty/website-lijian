const solutionCopy = solutionCopyByLang[lang as keyof typeof solutionCopyByLang] ?? solutionCopyByLang.en;
---

<BaseLayout
  lang={lang}
  title={t.seo.applicationsTitle}
  description={t.seo.applicationsDescription}
  path={path}
  image={productImages.manufacturing}
  pageEvent="view_application_page"
  pageEventLabel="all-applications"
  jsonLd={[breadcrumb, buildApplicationsItemListJsonLd(lang, site)]}
>
  <PageHero eyebrow={t.labels.applicationRange} title={t.seo.applicationsTitle} lead={t.seo.applicationsDescription} image={productImages.environment} imageAlt={t.nav.applications} />

  <section class="bg-white py-16 md:py-20">
    <div class="container-page">
      <SectionHeading title={t.nav.applications} lead={t.home.applicationsLead} />
      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        {applications.map((application) => (
          <a
            href={withLang(lang, `/applications/${application.slug}`)}
            class="group grid overflow-hidden rounded-[6px] border border-slate-200 bg-white shadow-sm transition-colors hover:border-[var(--color-blue)] md:grid-cols-[.92fr_1.08fr]"
            data-track="click_application_detail"
            data-track-label={application.slug}
          >
            <div class="relative min-h-[260px] overflow-hidden bg-slate-100">
              <Img src={application.image} alt={localize(application.name, lang)} class="h-full min-h-[260px] w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]" loading="lazy" />
            </div>
            <div class="flex flex-col p-6">
              <p class="text-xs font-semibold uppercase text-[var(--color-green)]">{solutionCopy.problem}</p>
              <h2 class="mt-3 text-2xl font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-blue)]">{localize(application.name, lang)}</h2>
              <p class="mt-4 text-sm leading-7 text-slate-600">{solutionCopy.items[application.slug as keyof typeof solutionCopy.items]}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {localizeList(application.focus, lang).map((item) => (
                  <span class="rounded-[4px] bg-[var(--color-mist)] px-2.5 py-1 text-xs font-semibold text-slate-600">{item}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
