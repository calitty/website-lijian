---
import ProductCard from "@/components/ProductCard.astro";
import PageHero from "@/components/PageHero.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  applications,
  getApplication,
  langCodes,
  localize,
  localizeList,
  products,
  ui,
  withLang,
  type Lang,
} from "@/data/site";

export function getStaticPaths() {
  return langCodes.flatMap((lang) =>
    applications.map((application) => ({
      params: { lang, slug: application.slug },
      props: { application },
    })),
  );
}

const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug as string;
const application = Astro.props.application ?? getApplication(slug);
if (!application) {
  throw new Error(`Unknown application slug: ${slug}`);
}

const t = ui[lang];
const name = localize(application.name, lang);
const summary = localize(application.summary, lang);
const pageDescription = `${summary} ${t.seo.applicationsDescription}`;
const relatedProducts = products.filter((product) => (application.blades as readonly string[]).includes(product.slug));
const path = `/applications/${application.slug}`;
const site = Astro.site ?? new URL("https://lijianblades.com");
const pageUrl = new URL(`/${lang}${path}/`, site).href;
const copyByLang = {
  en: { focus: "Blade Focus" },
  ru: { focus: "Фокус Ножа" },
  ar: { focus: "تركيز الشفرة" },
  es: { focus: "Enfoque de cuchilla" },
  pt: { focus: "Foco da lâmina" },
  tr: { focus: "Bıçak odağı" },
  de: { focus: "Messerfokus" },
  fr: { focus: "Focus lame" },
  it: { focus: "Focus lama" },
  th: { focus: "จุดสำคัญของใบมีด" },
  vi: { focus: "Trọng tâm dao" },
  id: { focus: "Fokus pisau" },
  zh: { focus: "刀片关注点" },
} as const;
const copy = copyByLang[lang as keyof typeof copyByLang] ?? copyByLang.en;
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: t.nav.home,
      item: new URL(`/${lang}/`, site).href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: t.nav.applications,
      item: new URL(`/${lang}/applications/`, site).href,
    },
    {
      "@type": "ListItem",
      position: 3,
      name,
      item: pageUrl,
    },
  ],
};
const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `${name} blade matching`,
  serviceType: "Custom food processing blade manufacturing",
  description: pageDescription,
  url: pageUrl,
  provider: {
    "@type": "Organization",
    name: t.siteName,
  },
  areaServed: ["Russia", "Kazakhstan", "Belarus", "Indonesia", "Southeast Asia", "China", "Global"],
};
---

<BaseLayout
  lang={lang}
  title={`${name} | ${t.seo.applicationsTitle}`}
  description={pageDescription}
  path={path}
  image={application.image}
  jsonLd={[breadcrumbJsonLd, serviceJsonLd]}
  pageEvent="view_application_page"
  pageEventLabel={application.slug}
>
  <PageHero eyebrow={t.nav.applications} title={name} lead={summary} image={application.image} imageAlt={name}>
      <div class="mt-7 flex flex-wrap gap-2">
        {localizeList(application.focus, lang).map((item) => (
          <span class="rounded-[4px] border border-white/15 bg-white/10 px-3 py-2 text-xs font-semibold text-slate-100">{item}</span>
        ))}
      </div>
  </PageHero>

  <section class="bg-white py-16 md:py-20">
    <div class="container-page grid gap-12 lg:grid-cols-[.86fr_1.14fr]">
      <div>
        <SectionHeading title={t.labels.typicalApplications} />
        <p class="mt-5 text-base leading-8 text-slate-600">
          {summary}
        </p>
        <div class="mt-8 rounded-[6px] border border-slate-200 bg-[var(--color-mist)] p-6">
          <h2 class="text-xl font-semibold text-[var(--color-ink)]">{copy.focus}</h2>
          <div class="mt-5 grid gap-3 sm:grid-cols-2">
            {localizeList(application.focus, lang).map((item) => (
              <span class="rounded-[4px] bg-white px-3 py-3 text-sm font-semibold text-slate-700 shadow-sm">{item}</span>
            ))}
          </div>
        </div>
        <a href={withLang(lang, "/contact")} class="mt-8 inline-flex rounded-[4px] bg-[var(--color-red)] px-5 py-3 font-semibold text-white" data-track="click_contact_from_product" data-track-label={application.slug}>
          {t.actions.contactUs}
        </a>
      </div>
      <div>
        <SectionHeading title={t.nav.products} />
        <div class="mt-5 grid gap-6">
          {relatedProducts.map((product) => <ProductCard product={product} lang={lang} />)}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
