---
import Img from "@/components/Img.astro";
import PageHero from "@/components/PageHero.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getSeoGuide,
  guideIndexCopy,
  guideLangCodes,
  guideNavLabel,
  localizeGuideList,
  localizeGuideText,
  seoGuides,
  type SeoGuide,
} from "@/data/guides";
import {
  buildBreadcrumb,
  channelLinks,
  contact,
  getApplication,
  getProduct,
  localize,
  ui,
  withLang,
  type Lang,
} from "@/data/site";

export function getStaticPaths() {
  return guideLangCodes.flatMap((lang) =>
    seoGuides.map((guide) => ({
      params: { lang, slug: guide.slug },
      props: { guide },
    })),
  );
}

const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug as string;
const guide = (Astro.props.guide as SeoGuide | undefined) ?? getSeoGuide(slug);
if (!guide) {
  throw new Error(`Unknown guide slug: ${slug}`);
}

const t = ui[lang];
const guideLabel = guideNavLabel(lang);
const title = localizeGuideText(guide.title, lang);
const description = localizeGuideText(guide.description, lang);
const path = `/guides/${guide.slug}`;
const site = Astro.site ?? new URL("https://lijianblades.com");
const pageUrl = new URL(withLang(lang, path), site).href;
const relatedProducts = guide.relatedProducts.map((productSlug) => getProduct(productSlug)).filter(Boolean);
const relatedApplications = guide.relatedApplications.map((applicationSlug) => getApplication(applicationSlug)).filter(Boolean);
const breadcrumb = buildBreadcrumb(lang, site, [
  { name: t.nav.home, path: "/" },
  { name: guideLabel, path: "/guides" },
  { name: title, path },
]);
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  image: new URL(guide.image, site).href,
  url: pageUrl,
  inLanguage: lang,
  author: {
    "@type": "Organization",
    name: contact.company[lang],
  },
  publisher: {
    "@type": "Organization",
    name: contact.company[lang],
    logo: {
      "@type": "ImageObject",
      url: new URL(contact.logo, site).href,
    },
  },
  about: guide.keywords,
  mainEntityOfPage: pageUrl,
};
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: title,
      acceptedAnswer: {
        "@type": "Answer",
        text: localizeGuideText(guide.shortAnswer, lang),
      },
    },
  ],
};
---

<BaseLayout
  lang={lang}
  title={title}
  description={description}
  path={path}
  image={guide.image}
  type="article"
  pageEvent="view_seo_guide"
  pageEventLabel={guide.slug}
  jsonLd={[breadcrumb, articleJsonLd, faqJsonLd]}
  alternateLangs={guideLangCodes}
>
  <PageHero eyebrow={guideLabel} title={title} lead={localizeGuideText(guide.lead, lang)} image={guide.image} imageAlt={title}>
    <div class="mt-7 flex flex-wrap gap-2">
      {guide.keywords.slice(0, 4).map((keyword) => (
        <span class="rounded-[4px] border border-white/15 bg-white/10 px-3 py-2 text-xs font-semibold text-slate-100">{keyword}</span>
      ))}
    </div>
  </PageHero>

  <section class="bg-white py-16 md:py-20">
    <div class="container-page grid gap-10 lg:grid-cols-[.72fr_.28fr]">
      <article class="min-w-0">
        <section class="rounded-[6px] border border-slate-200 bg-[var(--color-mist)] p-5 md:p-6">
          <p class="text-xs font-semibold uppercase text-[var(--color-blue)]">{localizeGuideText(guideIndexCopy.shortAnswer, lang)}</p>
          <h2 class="mt-3 text-2xl font-semibold leading-tight text-[var(--color-ink)]">{title}</h2>
          <p class="mt-4 text-base leading-8 text-slate-700">{localizeGuideText(guide.shortAnswer, lang)}</p>
        </section>

        <div class="mt-10 grid gap-10">
          {guide.sections.map((section) => (
            <section id={section.id} class="scroll-mt-24">
              <SectionHeading title={localizeGuideText(section.heading, lang)} />
              <p class="mt-5 text-base leading-8 text-slate-600">{localizeGuideText(section.body, lang)}</p>
              {section.bullets && (
                <div class="mt-5 grid gap-3 sm:grid-cols-3">
                  {localizeGuideList(section.bullets, lang).map((item) => (
                    <span class="rounded-[4px] border border-slate-200 bg-white px-4 py-3 text-sm font-semibold leading-6 text-slate-700 shadow-sm">{item}</span>
                  ))}
                </div>
              )}
            </section>
          ))}
        </div>

        <section class="mt-12 rounded-[6px] border border-slate-200 bg-slate-50 p-5 md:p-6">
          <div class="grid gap-6 lg:grid-cols-[1fr_.72fr] lg:items-center">
            <div>
              <SectionHeading title={localizeGuideText(guideIndexCopy.contact, lang)} lead={description} />
              <div class="mt-5 flex flex-wrap gap-3">
                <a href={withLang(lang, "/contact")} class="rounded-[4px] bg-[var(--color-blue)] px-5 py-3 text-sm font-semibold text-white" data-track="click_contact_from_guides" data-track-label={guide.slug}>
                  {t.actions.contactUs}
                </a>
                <a href={channelLinks.email} class="rounded-[4px] border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-[var(--color-ink)]" data-track="click_email" data-track-label={guide.slug}>
                  Email
                </a>
                <a href="/downloads/lijian-blades-product-catalog.pdf" class="rounded-[4px] border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-[var(--color-ink)]" download data-track="download_catalog" data-track-label={guide.slug}>
                  {localizeGuideText(guideIndexCopy.catalog, lang)}
                </a>
              </div>
            </div>
            <Img src="/images/lijian/export-packed-blade-sets.jpg" alt={localizeGuideText(guideIndexCopy.contact, lang)} class="aspect-[4/3] w-full rounded-[6px] object-cover" loading="lazy" />
          </div>
        </section>
      </article>

      <aside class="h-fit rounded-[6px] border border-slate-200 bg-white p-6 shadow-sm lg:sticky lg:top-24">
        <p class="text-xs font-semibold uppercase text-[var(--color-green)]">{localizeGuideText(guide.checklistTitle, lang)}</p>
        <div class="mt-5 grid gap-3">
          {localizeGuideList(guide.checklist, lang).map((item) => (
            <span class="rounded-[4px] bg-[var(--color-mist)] px-3 py-2 text-sm font-semibold leading-6 text-slate-700">{item}</span>
          ))}
        </div>

        <div class="mt-7 border-t border-slate-200 pt-6">
          <p class="text-xs font-semibold uppercase text-slate-400">{t.nav.products}</p>
          <div class="mt-3 grid gap-2">
            {relatedProducts.map((product) => (
              product && (
                <a href={withLang(lang, `/products/${product.slug}`)} class="rounded-[4px] border border-slate-200 px-3 py-2 text-sm font-semibold leading-6 text-[var(--color-ink)] hover:border-[var(--color-blue)]" data-track="click_product_detail" data-track-label={product.slug}>
                  {localize(product.name, lang)}
                </a>
              )
            ))}
          </div>
        </div>

        <div class="mt-7 border-t border-slate-200 pt-6">
          <p class="text-xs font-semibold uppercase text-slate-400">{t.nav.applications}</p>
          <div class="mt-3 grid gap-2">
            {relatedApplications.map((application) => (
              application && (
                <a href={withLang(lang, `/applications/${application.slug}`)} class="rounded-[4px] border border-slate-200 px-3 py-2 text-sm font-semibold leading-6 text-[var(--color-ink)] hover:border-[var(--color-blue)]" data-track="click_application_detail" data-track-label={application.slug}>
                  {localize(application.name, lang)}
                </a>
              )
            ))}
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
