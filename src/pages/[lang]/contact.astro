---
import PageHero from "@/components/PageHero.astro";
import InquiryForm from "@/components/InquiryForm.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumb, channelLinks, contact, langCodes, productImages, ui, type Lang } from "@/data/site";

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = ui[lang];
const path = "/contact";
const site = Astro.site ?? new URL("https://lijianblades.com");
const breadcrumb = buildBreadcrumb(lang, site, [
  { name: t.nav.home, path: "/" },
  { name: t.nav.contact, path },
]);
const copyByLang = {
  en: {
    h1: "Contact Us for Custom Food Processing Blades",
    lead: "Use email, WhatsApp or phone to discuss blade drawings, sample photos, equipment models or blade dimensions.",
    direct: "Direct Contact",
    note: "For faster confirmation, include the blade drawing, old sample photo, equipment model, material request and expected quantity when you contact us.",
  },
  ru: {
    h1: "Связаться по изготовлению ножей для пищевого оборудования",
    lead: "Свяжитесь по Email, WhatsApp или телефону, чтобы обсудить чертежи, образцы, модель оборудования или размеры ножа.",
    direct: "Прямые контакты",
    note: "Для быстрой проверки укажите чертеж ножа, фото старого образца, модель оборудования, материал и количество.",
  },
  ar: {
    h1: "تواصل معنا لطلب شفرات آلات الأغذية",
    lead: "استخدم البريد الإلكتروني أو WhatsApp أو الهاتف لمناقشة الرسومات، صور العينات، موديل الجهاز أو أبعاد الشفرة.",
    direct: "تواصل مباشر",
    note: "للتأكيد بشكل أسرع، أرسل الرسم، صورة الشفرة القديمة، موديل الجهاز، المادة المطلوبة والكمية المتوقعة.",
  },
  es: {
    h1: "Contacto para cuchillas alimentarias a medida",
    lead: "Use email, WhatsApp o teléfono para hablar de planos, fotos de muestras, modelos de equipo o dimensiones.",
    direct: "Contacto directo",
    note: "Para una confirmación más rápida, incluya plano, foto de cuchilla usada, modelo de equipo, material y cantidad estimada.",
  },
  pt: {
    h1: "Contato para lâminas alimentícias sob medida",
    lead: "Use email, WhatsApp ou telefone para falar sobre desenhos, fotos de amostras, modelos de equipamento ou medidas.",
    direct: "Contato direto",
    note: "Para confirmar mais rápido, envie desenho, foto da lâmina antiga, modelo do equipamento, material e quantidade estimada.",
  },
  tr: {
    h1: "Özel gıda makinesi bıçakları için iletişim",
    lead: "Çizim, numune fotoğrafı, ekipman modeli veya ölçüleri email, WhatsApp ya da telefonla paylaşın.",
    direct: "Doğrudan iletişim",
    note: "Daha hızlı onay için çizim, eski bıçak fotoğrafı, ekipman modeli, malzeme ve tahmini adedi gönderin.",
  },
  de: {
    h1: "Kontakt für kundenspezifische Lebensmittelmaschinenmesser",
    lead: "Nutzen Sie Email, WhatsApp oder Telefon für Zeichnungen, Musterfotos, Maschinenmodelle oder Messermaße.",
    direct: "Direktkontakt",
    note: "Für schnellere Klärung senden Sie Zeichnung, Foto des alten Messers, Maschinenmodell, Materialwunsch und geschätzte Menge.",
  },
  fr: {
    h1: "Contact pour lames alimentaires sur mesure",
    lead: "Utilisez email, WhatsApp ou téléphone pour discuter plans, photos d'échantillons, modèles de machine ou dimensions.",
    direct: "Contact direct",
    note: "Pour confirmer plus vite, envoyez plan, photo de lame usée, modèle de machine, matériau demandé et quantité prévue.",
  },
  it: {
    h1: "Contatti per lame alimentari su misura",
    lead: "Usa email, WhatsApp o telefono per discutere disegni, foto campioni, modelli macchina o dimensioni lama.",
    direct: "Contatto diretto",
    note: "Per conferma più rapida, invia disegno, foto della lama usata, modello macchina, materiale e quantità prevista.",
  },
  th: {
    h1: "ติดต่อเราเรื่องใบมีดเครื่องจักรอาหารสั่งทำ",
    lead: "ใช้อีเมล WhatsApp หรือโทรศัพท์เพื่อคุยเรื่องแบบวาด รูปตัวอย่าง รุ่นเครื่องจักร หรือขนาดใบมีด",
    direct: "ช่องทางติดต่อโดยตรง",
    note: "เพื่อยืนยันได้เร็วขึ้น กรุณาระบุแบบวาด รูปใบมีดเก่า รุ่นเครื่อง วัสดุ และจำนวนที่ต้องการ",
  },
  vi: {
    h1: "Liên hệ đặt dao máy thực phẩm tùy chỉnh",
    lead: "Dùng email, WhatsApp hoặc điện thoại để trao đổi bản vẽ, ảnh mẫu cũ, model thiết bị hoặc kích thước dao.",
    direct: "Liên hệ trực tiếp",
    note: "Để xác nhận nhanh hơn, hãy gửi bản vẽ, ảnh dao cũ, model máy, yêu cầu vật liệu và số lượng dự kiến.",
  },
  id: {
    h1: "Hubungi Kami untuk Pisau Mesin Makanan Kustom",
    lead: "Gunakan email, WhatsApp atau telepon untuk membahas gambar pisau, foto sampel, model mesin atau ukuran pisau.",
    direct: "Kontak Langsung",
    note: "Untuk konfirmasi lebih cepat, sertakan gambar pisau, foto sampel lama, model mesin, permintaan material dan estimasi jumlah.",
  },
  zh: {
    h1: "联系沟通食品机械刀片定制需求",
    lead: "可通过邮箱、WhatsApp 或电话沟通刀片图纸、样品照片、设备型号和刀片尺寸。",
    direct: "直接联系方式",
    note: "可提供刀片图纸、旧刀样品照片、设备型号、材料要求和预计数量，用于确认刀片规格。",
  },
} as const;
const copy = copyByLang[lang as keyof typeof copyByLang] ?? copyByLang.en;
const contactLabelsByLang = {
  en: { address: "Address", phone: "Phone" },
  ru: { address: "Адрес", phone: "Телефон" },
  ar: { address: "العنوان", phone: "الهاتف" },
  es: { address: "Dirección", phone: "Teléfono" },
  pt: { address: "Endereço", phone: "Telefone" },
  tr: { address: "Adres", phone: "Telefon" },
  de: { address: "Adresse", phone: "Telefon" },
  fr: { address: "Adresse", phone: "Téléphone" },
  it: { address: "Indirizzo", phone: "Telefono" },
  th: { address: "ที่อยู่", phone: "โทรศัพท์" },
  vi: { address: "Địa chỉ", phone: "Điện thoại" },
  id: { address: "Alamat", phone: "Telepon" },
  zh: { address: "地址", phone: "电话" },
} as const;
const contactLabels = contactLabelsByLang[lang as keyof typeof contactLabelsByLang] ?? contactLabelsByLang.en;
type Channel = [string, string, string, string];
const channels: Channel[] = [
  ["Email", contact.email, channelLinks.email, "click_email"],
  ["WhatsApp", contact.whatsapp, channelLinks.whatsapp, "click_whatsapp"],
  contact.telegram ? ["Telegram", `@${contact.telegram}`, channelLinks.telegram, "click_telegram"] : null,
  contact.linkedin ? ["LinkedIn", "Company page", channelLinks.linkedin, "click_linkedin"] : null,
  contact.wechat ? ["WeChat", contact.wechat, channelLinks.wechat, "click_wechat"] : null,
].filter((channel): channel is Channel => Boolean(channel));
---

<BaseLayout lang={lang} title={t.seo.contactTitle} description={t.seo.contactDescription} path={path} image={productImages.hero} jsonLd={[breadcrumb]}>
  <PageHero eyebrow={t.nav.contact} title={copy.h1} lead={copy.lead} image={productImages.workshop} imageAlt={t.nav.contact} />

  <section class="bg-[var(--color-mist)] py-16 md:py-20">
    <div class="container-page">
      <SectionHeading title={copy.direct} lead={copy.note} />
      <div class="mt-10 grid gap-6 lg:grid-cols-[1.05fr_.95fr] lg:items-start">
        <InquiryForm lang={lang} tone="light" />

        <aside class="rounded-[6px] border border-slate-200 bg-white p-5 shadow-sm">
          <div class="grid gap-4 sm:grid-cols-[130px_1fr] sm:items-center">
            <div class="rounded-[6px] border border-slate-200 bg-[var(--color-mist)] p-2">
              <img src={contact.whatsappQr} alt={t.labels.whatsappQr} class="aspect-square w-full rounded-[4px] object-contain" loading="lazy" />
            </div>
            <div>
              <p class="text-xs font-semibold uppercase text-[var(--color-red)]">{t.labels.whatsappQr}</p>
              <h2 class="mt-2 text-2xl font-semibold leading-snug text-[var(--color-ink)]">{t.labels.scanWhatsapp}</h2>
              <p class="mt-3 text-sm leading-7 text-slate-600">{t.contactPrompt}</p>
              <a href={channelLinks.whatsapp} class="mt-4 inline-flex rounded-[4px] bg-[#25d366] px-4 py-3 text-sm font-semibold text-[#06130b]" data-track="click_whatsapp">
                {t.labels.openWhatsapp}
              </a>
            </div>
          </div>

          <div class="mt-5 grid gap-3 border-t border-slate-200 pt-5 sm:grid-cols-2">
            {channels.map(([label, value, href, event]) => (
              <a href={href} class="rounded-[4px] border border-slate-200 bg-[var(--color-mist)] p-4" data-track={event}>
                <span class="block text-xs font-semibold uppercase text-slate-500">{label}</span>
                <span class="mt-2 block break-all text-sm font-semibold text-[var(--color-ink)]">{value}</span>
              </a>
            ))}
          </div>

          <div class="mt-5 grid gap-3 border-t border-slate-200 pt-5">
            {contact.departments.map((department) => (
              <a
                href={`tel:${department.phone.replace(/\s/g, "")}`}
                class="grid gap-3 rounded-[4px] border border-slate-200 bg-[var(--color-mist)] p-4 sm:grid-cols-[1fr_auto]"
                data-track="click_phone"
                data-track-label={department.id}
                aria-label={`${contactLabels.phone}: ${department.phone}`}
              >
                <span>
                  <span class="block text-sm font-semibold text-[var(--color-ink)]">{department.name[lang]}</span>
                  <span class="mt-1 block text-xs leading-5 text-slate-600">
                    <span class="font-semibold text-slate-800">{contactLabels.address}: </span>{department.address[lang]}
                  </span>
                </span>
                <span class="text-sm font-semibold text-[var(--color-blue)]">{department.phone}</span>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
