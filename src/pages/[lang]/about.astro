const fallbackAbout = aboutFallbackByLang[lang as keyof typeof aboutFallbackByLang];
const copy =
  copyByLang[lang as keyof typeof copyByLang] ??
  (fallbackAbout
    ? {
        ...fallbackAbout,
        stats: [
          { value: "1998", label: fallbackAbout.stats[0] },
          { value: "6,000 m²", label: fallbackAbout.stats[1] },
          { value: "80%", label: fallbackAbout.stats[2] },
          { value: "1M+", label: fallbackAbout.stats[3] },
          { value: "7 Days", label: fallbackAbout.stats[4] },
          { value: "30 Days", label: fallbackAbout.stats[5] },
          { value: "Nanjing Lukou Airport", label: fallbackAbout.stats[6] },
        ],
        sections: fallbackAbout.sections.map(([title, text], index) => ({
          title,
          text,
          image: [productImages.manufacturing, productImages.workshop, productImages.quality, productImages.environment][index],
        })),
      }
    : copyByLang.en);
---

<BaseLayout lang={lang} title={t.seo.aboutTitle} description={t.seo.aboutDescription} path={path} image={productImages.factoryGate} jsonLd={[breadcrumb]}>
  <PageHero eyebrow={t.nav.about} title={copy.h1} lead={copy.lead} image={productImages.factoryGate} imageAlt={t.nav.about}>
    <div class="mt-8 flex flex-wrap gap-3">
      {copy.chips.map((chip) => (
        <span class="rounded-[4px] border border-white/15 bg-white/10 px-4 py-3 text-sm font-semibold">{chip}</span>
      ))}
    </div>
  </PageHero>

  <section class="bg-white py-16 md:py-20">
    <div class="container-page grid gap-10 lg:grid-cols-[.9fr_1.1fr] lg:items-center">
      <div>
        <SectionHeading eyebrow={contact.company[lang]} title={copy.introTitle} lead={copy.intro} />
        <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {copy.stats.map((item) => (
            <div class="rounded-[6px] border border-slate-200 bg-[var(--color-mist)] p-4">
              <p class="text-2xl font-semibold text-[var(--color-ink)]">{item.value}</p>
              <p class="mt-1 text-sm font-semibold text-slate-600">{item.label}</p>
            </div>
          ))}
        </div>
        <a href={withLang(lang, "/contact")} class="mt-8 inline-flex rounded-[4px] bg-[var(--color-blue)] px-5 py-3 font-semibold text-white" data-track="click_contact_from_about">
          {t.actions.contactUs}
        </a>
      </div>
      <div class="grid gap-4 sm:grid-cols-[.85fr_1.15fr]">
        <img src={productImages.equipment} alt={copy.sections[3].title} class="aspect-[4/5] w-full rounded-[6px] object-cover shadow-sm" loading="lazy" />
        <div class="grid gap-4">
          <img src={productImages.manufacturing} alt={copy.sections[0].title} class="aspect-[4/3] w-full rounded-[6px] object-cover shadow-sm" loading="lazy" />
          <img src={productImages.quality} alt={copy.sections[2].title} class="aspect-[4/3] w-full rounded-[6px] object-cover shadow-sm" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-mist)] py-16 md:py-20">
    <div class="container-page">
      <SectionHeading title={copy.workshopTitle} lead={copy.workshopLead} />
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {copy.sections.map((section, index) => (
          <article class="overflow-hidden rounded-[6px] border border-slate-200 bg-white shadow-sm">
            <img src={section.image} alt={section.title} class="aspect-[16/10] w-full object-cover" loading="lazy" />
            <div class="p-6">
              <span class="text-sm font-semibold text-[var(--color-green)]">{String(index + 1).padStart(2, "0")}</span>
              <h2 class="mt-3 text-2xl font-semibold leading-snug text-[var(--color-ink)]">{section.title}</h2>
              <p class="mt-4 text-sm leading-7 text-slate-600">{section.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#102333] py-16 text-white md:py-20">
    <div class="container-page grid gap-10 lg:grid-cols-[.85fr_1.15fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase text-[var(--color-silver)]">{t.actions.contactUs}</p>
        <h2 class="mt-3 text-3xl font-semibold leading-tight md:text-4xl">{copy.cooperationTitle}</h2>
        <p class="mt-4 text-base leading-8 text-slate-300">{t.contactPrompt}</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {copy.cooperation.map((item) => (
          <div class="rounded-[4px] border border-white/10 bg-white/5 px-4 py-4 text-sm font-semibold text-slate-100">{item}</div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
