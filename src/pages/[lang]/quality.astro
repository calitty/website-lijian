    lead: "Gambar laporan menunjukkan contoh kemampuan verifikasi teknis. Untuk produksi batch, item inspeksi dan dokumen mengikuti persyaratan pesanan.",
    note: "Screenshot laporan asli dipertahankan untuk kredibilitas; keterangan terjemahan menjelaskan tujuan bagi pembeli internasional.",
    chips: ["Morfologi mata", "Cek elemen", "Review heat treatment", "Rentang kekerasan"],
    items: [
      ["Observasi SEM mata pisau", "Gambar mikroskop elektron membantu meninjau morfologi mata, jejak patah, aus, dan fitur permukaan abnormal."],
      ["Analisis komposisi EDS", "Spektrum elemen memeriksa area yang dianalisis dan mendukung review material."],
      ["Struktur metalografi", "Mikrostruktur membantu menilai kondisi heat treatment, keseragaman matriks, dan segregasi karbida yang jelas."],
      ["Analisis kekerasan", "Pembacaan kekerasan di beberapa posisi membantu menilai konsistensi heat treatment dan rentang target."],
    ],
  },
} as const;
const qualityEvidenceFallback = qualityEvidenceFallbackByLang[lang as keyof typeof qualityEvidenceFallbackByLang];
const evidenceImages = [
  "/images/quality/report-sem-cropped.jpg",
  "/images/quality/report-eds-cropped.jpg",
  "/images/quality/report-metallography-cropped.jpg",
  "/images/quality/report-hardness-cropped.jpg",
];
const qualityEvidence =
  qualityEvidenceByLang[lang as keyof typeof qualityEvidenceByLang] ??
  (qualityEvidenceFallback
    ? {
        ...qualityEvidenceFallback,
        items: qualityEvidenceFallback.items.map(([title, text], index) => ({
          title,
          text,
          image: evidenceImages[index],
        })),
      }
    : qualityEvidenceByLang.en);
const evidenceFeatured = qualityEvidence.items[0];
const evidenceSupporting = qualityEvidence.items.slice(1);
---

<BaseLayout lang={lang} title={t.seo.qualityTitle} description={t.seo.qualityDescription} path={path} image={productImages.quality} jsonLd={[breadcrumb]}>
  <PageHero eyebrow={t.labels.inspection} title={copy.h1} lead={copy.lead} image={productImages.quality} imageAlt={t.nav.quality} />

  <section class="bg-white py-16 md:py-20">
    <div class="container-page grid gap-10 lg:grid-cols-[.86fr_1.14fr] lg:items-start">
      <div>
        <SectionHeading title={copy.principleTitle} lead={copy.principleLead} />
        <div class="mt-8 overflow-hidden rounded-[6px] border border-slate-200 bg-[var(--color-mist)] shadow-sm">
          <img src={productImages.workshop} alt={copy.principleTitle} class="aspect-[16/10] w-full object-cover" loading="lazy" />
          <div class="p-6">
            <h2 class="text-xl font-semibold text-[var(--color-ink)]">{copy.documentsTitle}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">{copy.documentsLead}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {copy.documents.map((item) => (
                <span class="rounded-[4px] bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm">{item}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div>
        {
          zhQualityValue && (
            <div class="mb-6 rounded-[6px] border border-slate-200 bg-[var(--color-mist)] p-6">
              <h2 class="text-2xl font-semibold leading-snug text-[var(--color-ink)]">{zhQualityValue.title}</h2>
              <p class="mt-4 text-sm leading-7 text-slate-600">{zhQualityValue.lead}</p>
              <div class="mt-6 grid gap-4 md:grid-cols-2">
                {zhQualityValue.cards.map((card) => (
                  <article class="rounded-[6px] border border-slate-100 bg-white p-5">
                    <h3 class="text-lg font-semibold text-[var(--color-ink)]">{card.title}</h3>
                    <p class="mt-3 text-sm leading-7 text-slate-600">{card.text}</p>
                  </article>
                ))}
              </div>
            </div>
          )
        }
        <div class="grid gap-4 md:grid-cols-2">
          {copy.points.map((point, index) => (
            <article class="rounded-[6px] border border-slate-200 bg-white p-6 shadow-sm">
              <span class="text-sm font-semibold text-[var(--color-green)]">{String(index + 1).padStart(2, "0")}</span>
              <h2 class="mt-3 text-xl font-semibold leading-snug text-[var(--color-ink)]">{point.title}</h2>
              <p class="mt-3 text-sm leading-7 text-slate-600">{point.text}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="inspection-reports" class="scroll-mt-24 bg-[var(--color-mist)] py-16 md:py-20">
    <div class="container-page">
      <div class="grid gap-6 lg:grid-cols-[.72fr_1.28fr] lg:items-end">
        <div>
          <p class="text-sm font-semibold uppercase text-[var(--color-blue)]">{t.labels.inspection}</p>
          <h2 class="mt-3 text-3xl font-semibold leading-tight text-[var(--color-ink)] md:text-4xl">{qualityEvidence.title}</h2>
        </div>
        <div>
          <p class="text-base leading-8 text-slate-600">{qualityEvidence.lead}</p>
          <p class="mt-3 rounded-[6px] border border-slate-200 bg-white p-4 text-sm leading-7 text-slate-600 shadow-sm">{qualityEvidence.note}</p>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-2">
        {qualityEvidence.chips.map((item) => (
          <span class="rounded-[4px] border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 shadow-sm">{item}</span>
        ))}
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-[1.08fr_.92fr]">
        <article class="overflow-hidden rounded-[6px] border border-slate-200 bg-white text-[var(--color-ink)] shadow-sm">
          <div class="flex items-center justify-between gap-4 border-b border-slate-200 bg-[var(--color-mist)] px-5 py-4">
            <div>
              <span class="text-xs font-semibold uppercase text-[var(--color-blue)]">01 / Report sample</span>
              <h3 class="mt-1 text-xl font-semibold leading-snug">{evidenceFeatured.title}</h3>
            </div>
            <span class="hidden rounded-[4px] border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-500 sm:inline-flex">{t.labels.inspection}</span>
          </div>
          <div class="bg-white p-3">
            <img src={evidenceFeatured.image} alt={evidenceFeatured.title} class="aspect-[16/10] w-full rounded-[4px] object-contain" loading="lazy" />
          </div>
          <div class="border-t border-slate-200 p-5">
            <p class="text-sm leading-7 text-slate-600">{evidenceFeatured.text}</p>
          </div>
        </article>

        <div class="grid gap-4">
          {evidenceSupporting.map((item, index) => (
            <article class="grid overflow-hidden rounded-[6px] border border-slate-200 bg-white text-[var(--color-ink)] shadow-sm sm:grid-cols-[220px_1fr]">
              <div class="bg-white p-2">
                <img src={item.image} alt={item.title} class="aspect-[16/9] h-full w-full rounded-[4px] object-contain" loading="lazy" />
              </div>
              <div class="border-t border-slate-200 p-4 sm:border-s sm:border-t-0">
                <span class="text-xs font-semibold uppercase text-[var(--color-blue)]">0{index + 2} / Evidence</span>
                <h3 class="mt-2 text-lg font-semibold leading-snug">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-600">{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-mist)] py-16 md:py-20">
    <div class="container-page">
      <SectionHeading title={copy.workflowTitle} lead={t.seo.qualityDescription} />
      <div class="mt-10 grid gap-3 md:grid-cols-7">
        {copy.workflow.map((step, index) => (
          <div class="relative rounded-[6px] border border-slate-200 bg-white p-4 shadow-sm">
            <span class="grid h-8 w-8 place-items-center rounded-[4px] bg-[var(--color-blue)] text-sm font-semibold text-white">{index + 1}</span>
            <h2 class="mt-4 text-sm font-semibold leading-6 text-[var(--color-ink)]">{step}</h2>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
