---
import PageHero from "@/components/PageHero.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumb, faqItems, langCodes, localize, productImages, ui, withLang, type Lang } from "@/data/site";

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = ui[lang];
const path = "/faq";
const site = Astro.site ?? new URL("https://lijianblades.com");

const copyByLang = {
  en: {
    eyebrow: "Buyer FAQ",
    h1: "Food Machinery Blade FAQ",
    lead:
      "Common questions from overseas buyers about custom and replacement food machinery blades — drawings, samples, materials, lead time, MOQ, OEM and export.",
    cta: "Send your blade requirement",
  },
  ru: {
    eyebrow: "Вопросы покупателей",
    h1: "Ножи для пищевого оборудования: FAQ",
    lead:
      "Частые вопросы зарубежных покупателей: чертежи, образцы, материалы, сроки, минимальный заказ, OEM и экспорт.",
    cta: "Отправить запрос по ножам",
  },
  ar: {
    eyebrow: "أسئلة المشترين",
    h1: "أسئلة شفرات آلات الأغذية",
    lead: "أسئلة شائعة من المشترين الخارجيين حول الشفرات المخصصة والبديلة: الرسومات، العينات، المواد، المدة، الحد الأدنى، OEM والتصدير.",
    cta: "أرسل متطلبات الشفرة",
  },
  es: {
    eyebrow: "FAQ del comprador",
    h1: "FAQ de cuchillas para maquinaria alimentaria",
    lead:
      "Preguntas frecuentes de compradores internacionales sobre cuchillas personalizadas y recambios: planos, muestras, materiales, plazo, MOQ, OEM y exportación.",
    cta: "Enviar requisito de cuchilla",
  },
  pt: {
    eyebrow: "FAQ do comprador",
    h1: "FAQ de lâminas para máquinas alimentícias",
    lead:
      "Perguntas frequentes de compradores internacionais sobre lâminas sob medida e reposições: desenhos, amostras, materiais, prazo, MOQ, OEM e exportação.",
    cta: "Enviar necessidade de lâmina",
  },
  tr: {
    eyebrow: "Alıcı SSS",
    h1: "Gıda makinesi bıçakları SSS",
    lead:
      "Yurt dışı alıcıların özel ve yedek gıda makinesi bıçakları hakkında sık sorduğu konular: çizim, numune, malzeme, süre, MOQ, OEM ve ihracat.",
    cta: "Bıçak ihtiyacınızı gönderin",
  },
  de: {
    eyebrow: "Käufer-FAQ",
    h1: "FAQ zu Messern für Lebensmittelmaschinen",
    lead:
      "Häufige Fragen internationaler Käufer zu kundenspezifischen und Ersatzmessern: Zeichnungen, Muster, Materialien, Lieferzeit, Mindestmenge, OEM und Export.",
    cta: "Messeranforderung senden",
  },
  fr: {
    eyebrow: "FAQ acheteur",
    h1: "FAQ lames pour machines alimentaires",
    lead:
      "Questions fréquentes des acheteurs internationaux sur les lames sur mesure et de rechange : plans, échantillons, matériaux, délai, MOQ, OEM et export.",
    cta: "Envoyer votre besoin de lame",
  },
  it: {
    eyebrow: "FAQ acquirenti",
    h1: "FAQ lame per macchine alimentari",
    lead:
      "Domande frequenti degli acquirenti esteri su lame su misura e ricambi: disegni, campioni, materiali, tempi, MOQ, OEM ed export.",
    cta: "Invia richiesta lama",
  },
  th: {
    eyebrow: "FAQ สำหรับผู้ซื้อ",
    h1: "คำถามใบมีดเครื่องจักรอาหาร",
    lead: "คำถามทั่วไปจากผู้ซื้อต่างประเทศเกี่ยวกับใบมีดสั่งทำและใบมีดทดแทน: แบบ ตัวอย่าง วัสดุ ระยะเวลา MOQ OEM และการส่งออก",
    cta: "ส่งความต้องการใบมีด",
  },
  vi: {
    eyebrow: "FAQ người mua",
    h1: "FAQ dao máy thực phẩm",
    lead:
      "Câu hỏi thường gặp của khách hàng quốc tế về dao tùy chỉnh và dao thay thế: bản vẽ, mẫu, vật liệu, thời gian, MOQ, OEM và xuất khẩu.",
    cta: "Gửi yêu cầu dao",
  },
  zh: {
    eyebrow: "采购常见问题",
    h1: "食品机械刀片常见问题",
    lead: "海外采购关于食品机械刀片定制与替换的常见问题：图纸、样品、材料、交期、起订量、OEM 与出口。",
    cta: "提交刀片需求",
  },
  id: {
    eyebrow: "FAQ Pembeli",
    h1: "FAQ Pisau Mesin Makanan",
    lead:
      "Pertanyaan umum pembeli luar negeri tentang pisau mesin makanan kustom dan pengganti — gambar, sampel, material, lead time, MOQ, OEM, dan ekspor.",
    cta: "Kirim kebutuhan pisau Anda",
  },
} as const;
const copy = copyByLang[lang as keyof typeof copyByLang] ?? copyByLang.en;

const breadcrumb = buildBreadcrumb(lang, site, [
  { name: t.nav.home, path: "/" },
  { name: copy.h1, path },
]);
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: localize(item.q, lang),
    acceptedAnswer: {
      "@type": "Answer",
      text: localize(item.a, lang),
    },
  })),
};
---

<BaseLayout
  lang={lang}
  title={copy.h1}
  description={copy.lead}
  path={path}
  image={productImages.quality}
  jsonLd={[breadcrumb, faqJsonLd]}
>
  <PageHero eyebrow={copy.eyebrow} title={copy.h1} lead={copy.lead} image={productImages.quality} imageAlt={copy.h1} />

  <section class="bg-white py-16 md:py-20">
    <div class="container-page max-w-3xl">
      <div class="grid gap-4">
        {faqItems.map((item) => (
          <article class="rounded-[6px] border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-[var(--color-ink)]">{localize(item.q, lang)}</h2>
            <p class="mt-3 text-base leading-8 text-slate-600">{localize(item.a, lang)}</p>
          </article>
        ))}
      </div>

      <div class="mt-10 flex flex-wrap gap-3">
        <a href={withLang(lang, "/contact")} class="rounded-[4px] bg-[var(--color-blue)] px-5 py-3 font-semibold text-white" data-track="click_contact_from_product" data-track-label="faq">
          {copy.cta}
        </a>
        <a href={withLang(lang, "/products")} class="rounded-[4px] border border-[var(--color-border)] px-5 py-3 font-semibold text-[var(--color-ink)]">
          {t.actions.viewProducts}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
